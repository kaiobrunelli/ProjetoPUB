.fpd-linha-progresso.ativa::before { content: ""; position: absolute; top: 0; bottom: 0; width: 40%; background: linear-gradient(90deg, transparent, var(--brand-500), var(--brand-700), transparent); animation: linhaCorrendo 1.1s ease-in-out infinite; }
@@keyframes linhaCorrendo { 0% { left: -40%; } 100% { left: 100%; } }
