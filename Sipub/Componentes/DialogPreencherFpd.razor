@using System.Globalization
@using System.Net.Http.Json
@using PlataformaNotificacao.Domain
@using PlataformaNotificacao.Domain.DTO
@using PlataformaNotificacao.Domain.Enum
@inject HttpClient Http
@inject IJSRuntime JS
@inject ServicoUsuario ServicoUsuario

<div class="overlay-fpd" @onclick="AoFechar"></div>

<div class="dialog-fpd" @onclick:stopPropagation>

    <!-- Cabeçalho -->
    <div class="dialog-fpd-header">
        <div class="dialog-fpd-icone"><i class="bi bi-clipboard-plus"></i></div>
        <div>
            <div class="dialog-fpd-titulo">FPD-AF</div>
            <div class="dialog-fpd-subtitulo">Ficha de Previsão de Desembolso</div>
        </div>
        <button class="dialog-fpd-fechar" @onclick="AoFechar" title="Fechar"><i class="bi bi-x-lg"></i></button>
    </div>

    <div class="dialog-fpd-corpo" @ref="_corpoRef">

        <!-- ── Linha de identificação ── -->
        <div class="fpd-ident">
            <div class="fpd-campo"><label class="fpd-label">Solicitante</label>
                <input class="fpd-input" value="@_fpd.Solicitante" readonly /></div>
            <div class="fpd-campo"><label class="fpd-label">GIGOV</label>
                <input class="fpd-input" @bind="_fpd.Gigov" @bind:after="InvalidarValidacao" /></div>
            <div class="fpd-campo"><label class="fpd-label">Gestor</label>
                <input class="fpd-input" @bind="_fpd.Gestor" @bind:after="InvalidarValidacao" /></div>
            <div class="fpd-campo"><label class="fpd-label">ID</label>
                <input class="fpd-input" @bind="_fpd.IdFpd" /></div>
            <div class="fpd-campo"><label class="fpd-label">FPD</label>
                <input class="fpd-input" @bind="_fpd.NumeroFpd" /></div>
            <div class="fpd-campo fpd-campo-af">
                <label class="fpd-label">Contrato AF <span class="fpd-obrigatorio">*</span></label>
                <div class="fpd-af-linha">
                    <input class="fpd-input" placeholder="Ex.: 0558698-45"
                           @bind="_fpd.ContratoAf" @bind:after="InvalidarValidacao" disabled="@_fpd.PrimeiroDesembolso" />
                    <button class="fpd-btn-buscar" @onclick="BuscarContrato" disabled="@(_buscando || _fpd.PrimeiroDesembolso)" title="Buscar na base">
                        @if (_buscando) { <i class="bi bi-arrow-repeat spin"></i> }
                        else            { <i class="bi bi-search"></i> }
                        <span>Buscar</span>
                    </button>
                </div>
                @if (!string.IsNullOrEmpty(_msgBusca))
                {
                    <span class="fpd-msg-busca @(_buscaOk ? "ok" : "falha")">@_msgBusca</span>
                }
            </div>
            <div class="fpd-campo"><label class="fpd-label">Solicitado</label>
                <input class="fpd-input" type="date" @bind="_fpd.DataSolicitado" /></div>
        </div>

        <label class="fpd-check fpd-check-destaque">
            <input type="checkbox" @bind="_fpd.PrimeiroDesembolso" @bind:after="AoMudarPrimeiroDesembolso" />
            <span>Este é o primeiro desembolso deste contrato</span>
        </label>

        <!-- ── Duas colunas ── -->
        <div class="fpd-2col">

            <!-- COLUNA ESQUERDA -->
            <div class="fpd-coluna">

                @RotuloCampo("Agente Financeiro", _fpd.AgenteFinanceiro, v => _fpd.AgenteFinanceiro = v, _fpd.CnpjAgenteFinanceiro, v => _fpd.CnpjAgenteFinanceiro = v)
                @RotuloCampo("Tomador / Mutuário", _fpd.Tomador, v => _fpd.Tomador = v, _fpd.CnpjTomador, v => _fpd.CnpjTomador = v)
                @RotuloCampo("Agente Técnico OP", _fpd.AgenteTecnico, v => _fpd.AgenteTecnico = v, _fpd.CnpjAgenteTecnico, v => _fpd.CnpjAgenteTecnico = v)
                @RotuloCampo("Agente Promotor", _fpd.AgentePromotor, v => _fpd.AgentePromotor = v, _fpd.CnpjAgentePromotor, v => _fpd.CnpjAgentePromotor = v)

                <div class="fpd-campo"><label class="fpd-label">Programa</label>
                    <input class="fpd-input" @bind="_fpd.Programa" /></div>

                <!-- Sim/Não em linha -->
                <div class="fpd-linha-sn">
                    <div class="fpd-sn-item">
                        <label class="fpd-label">Último desembolso</label>
                        <ToggleSimNao @bind-Value="_fpd.UltimoDesembolso" AoAlterar="InvalidarValidacao" ReadOnly="_fpd.PrimeiroDesembolso" />
                    </div>
                    @if (_fpd.UltimoDesembolso == "sim")
                    {
                        <div class="fpd-sn-item">
                            <label class="fpd-label">Funcionalidade</label>
                            <ToggleSimNao @bind-Value="_fpd.Funcionalidade" AoAlterar="InvalidarValidacao" />
                        </div>
                        <div class="fpd-sn-item">
                            <label class="fpd-label">Conclusão</label>
                            <ToggleSimNao @bind-Value="_fpd.Conclusao" AoAlterar="InvalidarValidacao" />
                        </div>
                    }
                </div>

                <div class="fpd-grid2">
                    <div class="fpd-campo"><label class="fpd-label">DT Emissão Eng.</label>
                        <input class="fpd-input" type="date" @bind="_fpd.DataEmissaoEng" /></div>
                    <div class="fpd-campo"><label class="fpd-label">Situação de obra</label>
                        <input class="fpd-input" @bind="_fpd.SituacaoObra" /></div>
                    <div class="fpd-campo">
                        <label class="fpd-label">DT Emissão Sócio-ambiental</label>
                        <div class="fpd-data-nsa">
                            <input class="fpd-input" type="date" @bind="_fpd.DataEmissaoSocioAmb" disabled="@_fpd.Nsa" />
                            <label class="fpd-check fpd-check-inline">
                                <input type="checkbox" @bind="_fpd.Nsa" /> <span>NSA</span>
                            </label>
                        </div>
                    </div>
                    <div class="fpd-campo"><label class="fpd-label">% de obra</label>
                        <input class="fpd-input" type="number" step="0.01" placeholder="0,00"
                               @bind="_fpd.PercObra" @bind:after="InvalidarValidacao" /></div>
                </div>

                <div class="fpd-linha-sn">
                    <div class="fpd-sn-item">
                        <label class="fpd-label">Tomador</label>
                        <ToggleSimNao @bind-Value="_fpd.TomadorAdimplente" AoAlterar="InvalidarValidacao" />
                        <span class="fpd-sn-legenda">adimplente</span>
                    </div>
                    <div class="fpd-sn-item">
                        <label class="fpd-label">Agente Promotor</label>
                        <ToggleSimNao @bind-Value="_fpd.PromotorAdimplente" AoAlterar="InvalidarValidacao" />
                        <span class="fpd-sn-legenda">adimplente</span>
                    </div>
                </div>

                <div class="fpd-check-destaque fpd-tipo-destaque">
                    <span class="fpd-tipo-rotulo">Tipo de desembolso</span>
                    <div class="fpd-tipo-opcoes">
                        <button type="button" class="fpd-tipo-opc @(_fpd.TipoDesembolso == "normal" ? "ativo" : "")"
                                @onclick='() => DefinirTipoDesembolso("normal")'>Normal</button>
                        <button type="button" class="fpd-tipo-opc @(_fpd.TipoDesembolso == "adiantamento" ? "ativo" : "")"
                                @onclick='() => DefinirTipoDesembolso("adiantamento")'>Adiantamento</button>
                    </div>
                </div>

                <div class="fpd-linha-sn">
                    <div class="fpd-sn-item"><label class="fpd-label">Retorno parcial</label>
                        <ToggleSimNao @bind-Value="_fpd.RetornoParcial" /></div>
                    <div class="fpd-sn-item"><label class="fpd-label">Placa local</label>
                        <ToggleSimNao @bind-Value="_fpd.PlacaLocal" AoAlterar="InvalidarValidacao" /></div>
                </div>

                <div class="fpd-linha-sn">
                    <div class="fpd-sn-item"><label class="fpd-label">Licença de instalação</label>
                        <ToggleSimNao @bind-Value="_fpd.LicencaInstalacao" ComNsa="true" /></div>
                    <div class="fpd-sn-item"><label class="fpd-label">Licença de operação</label>
                        <ToggleSimNao @bind-Value="_fpd.LicencaOperacao" ComNsa="true" /></div>
                </div>

                <div class="fpd-campo"><label class="fpd-label">OBS AF</label>
                    <textarea class="fpd-input fpd-textarea" placeholder="Observações do AF"
                              @bind="_fpd.ObsAf"></textarea></div>
            </div>

            <!-- COLUNA DIREITA -->
            <div class="fpd-coluna">

                <div class="fpd-campo"><label class="fpd-label">INSS OBS</label>
                    <textarea class="fpd-input fpd-textarea-sm" @bind="_fpd.InssObs"></textarea></div>

                <!-- Valores -->
                <div class="fpd-grid3">
                    <div class="fpd-campo"><label class="fpd-label">Solicitado VI</label>
                        <CampoMoeda @bind-Value="_fpd.SolicitadoVi" /></div>
                    <div class="fpd-campo"><label class="fpd-label">Glosado VI</label>
                        <CampoMoeda @bind-Value="_fpd.GlosadoVi" /></div>
                    <div class="fpd-campo"><label class="fpd-label">Aceito VI</label>
                        <CampoMoeda @bind-Value="_fpd.AceitoVi" /></div>
                </div>

                <div class="fpd-grid2">
                    <div class="fpd-campo"><label class="fpd-label">Participação FGTS <span class="fpd-obrigatorio">*</span></label>
                        <CampoMoeda @bind-Value="_fpd.ParticipacaoFgts" AoAlterar="InvalidarValidacao" /></div>
                    <div class="fpd-campo"><label class="fpd-label">Contrapartida</label>
                        <CampoMoeda @bind-Value="_fpd.Contrapartida" AoAlterar="InvalidarValidacao" /></div>
                    <div class="fpd-campo"><label class="fpd-label">VE (Valor Empréstimo) <span class="fpd-obrigatorio">*</span></label>
                        <CampoMoeda @bind-Value="_fpd.Ve" AoAlterar="InvalidarValidacao" /></div>
                    <div class="fpd-campo"><label class="fpd-label">CP Atual</label>
                        <CampoMoeda @bind-Value="_fpd.CpAtual" /></div>
                    <div class="fpd-campo"><label class="fpd-label">Desembolsado</label>
                        <CampoMoeda @bind-Value="_fpd.Desembolsado" /></div>
                    <div class="fpd-campo"><label class="fpd-label">Integralizado</label>
                        <CampoMoeda @bind-Value="_fpd.Integralizado" /></div>
                    <div class="fpd-campo"><label class="fpd-label">Parcela FGTS</label>
                        <CampoMoeda @bind-Value="_fpd.ParcelaFgts" /></div>
                    <div class="fpd-campo"><label class="fpd-label">Integralizar</label>
                        <CampoMoeda @bind-Value="_fpd.Integralizar" /></div>
                    <div class="fpd-campo"><label class="fpd-label">Saldo a desembolsar</label>
                        <CampoMoeda @bind-Value="_fpd.SaldoDesembolsar" /></div>
                    <div class="fpd-campo"><label class="fpd-label">Saldo a integralizar</label>
                        <CampoMoeda @bind-Value="_fpd.SaldoIntegralizar" /></div>
                </div>

                <div class="fpd-linha-sn">
                    <div class="fpd-sn-item"><label class="fpd-label">Excepcionalização</label>
                        <ToggleSimNao @bind-Value="_fpd.Excepcionalizacao" /></div>
                    <div class="fpd-sn-item"><label class="fpd-label">CP alterada</label>
                        <ToggleSimNao @bind-Value="_fpd.CpAlterada" /></div>
                </div>

                <!-- Tabela de percentuais (só com valores preenchidos) -->
                @if (_fpd.TemValoresFinanceiros)
                {
                    <div class="fpd-perc">
                        <div class="fpd-perc-titulo">Percentuais</div>
                        <div class="fpd-perc-linha"><span>FGTS</span><strong>@FmtPerc(_fpd.PercFgts)</strong></div>
                        <div class="fpd-perc-linha"><span>Contrapartida</span><strong>@FmtPerc(_fpd.PercContrapartida)</strong></div>
                        <div class="fpd-perc-linha global"><span>Global</span><strong>@FmtPerc(_fpd.PercGlobal)</strong></div>
                    </div>
                }
            </div>
        </div>

        <!-- ── Resultado da consulta prévia ── -->
        @if (_validando || _etapas.Any())
        {
            <div class="fpd-validacao">
                <div class="fpd-validacao-header">
                    <span>Consulta prévia no sistema</span>
                    @if (_status == StatusValidacao.Aprovado)  { <span class="fpd-validacao-tag ok">100% validado</span> }
                    @if (_status == StatusValidacao.Reprovado) { <span class="fpd-validacao-tag falha">pendências encontradas</span> }
                </div>
                <div class="fpd-linha-progresso @(_validando ? "ativa" : "")"></div>
                <div class="fpd-validacao-lista">
                    @foreach (var etapa in _etapas)
                    {
                        <div class="fpd-etapa @etapa.Estado">
                            @if (etapa.Estado == "executando") { <i class="bi bi-arrow-repeat spin"></i> }
                            else if (etapa.Estado == "ok")     { <i class="bi bi-check-circle-fill"></i> }
                            else                               { <i class="bi bi-x-circle-fill"></i> }
                            <span>@etapa.Texto</span>
                            @if (!string.IsNullOrEmpty(etapa.Detalhe)) { <span class="fpd-etapa-detalhe">@etapa.Detalhe</span> }
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <!-- Rodapé -->
    <div class="dialog-fpd-rodape">
        <div class="dialog-fpd-acoes">
            <button class="btn-fpd-cancelar" @onclick="AoFechar" disabled="@(_validando || _solicitando)">Cancelar</button>
            <button class="btn-fpd-validar" @onclick="Validar" disabled="@(_validando || _solicitando)">
                @if (_validando) { <i class="bi bi-arrow-repeat spin"></i> <span>Validando…</span> }
                else            { <i class="bi bi-shield-check"></i> <span>Validar</span> }
            </button>
            <button class="btn-fpd-solicitar" @onclick="Solicitar"
                    disabled="@(_status != StatusValidacao.Aprovado || _solicitando)"
                    title="@(_status == StatusValidacao.Aprovado ? "Enviar solicitação" : "Execute a validação antes de solicitar")">
                @if (_solicitando) { <i class="bi bi-arrow-repeat spin"></i> <span>Solicitando…</span> }
                else              { <i class="bi bi-send-check"></i> <span>Solicitar Desembolso</span> }
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public EventCallback AoFechar { get; set; }
    [Parameter, EditorRequired] public EventCallback<PreenchimentoFpd> AoSolicitar { get; set; }

    private enum StatusValidacao { Nenhum, Aprovado, Reprovado }

    private sealed class Etapa
    {
        public string Texto   { get; set; } = "";
        public string Estado  { get; set; } = "executando";
        public string Detalhe { get; set; } = "";
    }

    private readonly PreenchimentoFpd _fpd = new();
    private ElementReference _corpoRef;
    private bool _validando, _solicitando, _buscando, _buscaOk;
    private string? _msgBusca;
    private StatusValidacao _status = StatusValidacao.Nenhum;
    private readonly List<Etapa> _etapas = [];

    protected override void OnInitialized()
    {
        _fpd.Solicitante = ServicoUsuario.Matricula;   // matrícula do usuário logado
    }

    // Campo Nome + CNPJ reutilizável (agente financeiro/tomador/técnico/promotor)
    private RenderFragment RotuloCampo(string rotulo, string valor, Action<string> setValor,
                                       string cnpj, Action<string> setCnpj) =>
        @<div class="fpd-campo">
            <label class="fpd-label">@rotulo</label>
            <div class="fpd-agente-linha">
                <input class="fpd-input" value="@valor" @onchange="e => setValor(e.Value?.ToString() ?? string.Empty)" />
                <input class="fpd-input fpd-cnpj" placeholder="CNPJ" value="@cnpj"
                       @onchange="e => setCnpj(e.Value?.ToString() ?? string.Empty)" />
            </div>
        </div>;

    private static string FmtPerc(decimal? p) => p is null ? "—" : $"{p.Value.ToString("0.000", new CultureInfo("pt-BR"))}%";

    // ── BUSCAR contrato AF ──
    private async Task BuscarContrato()
    {
        if (_buscando || string.IsNullOrWhiteSpace(_fpd.ContratoAf)) return;
        _buscando = true;
        _msgBusca = null;
        StateHasChanged();
        try
        {
            var resp = await Http.GetAsync($"api/fpd/contrato?af={Uri.EscapeDataString(_fpd.ContratoAf)}");
            if (resp.IsSuccessStatusCode)
            {
                var c = await resp.Content.ReadFromJsonAsync<ContratoAfDto>();
                if (c is not null) PreencherDeContrato(c);
                _buscaOk = true;
                _msgBusca = "Contrato encontrado — campos preenchidos.";
            }
            else
            {
                _buscaOk = false;
                _msgBusca = "Contrato não encontrado — preencha manualmente.";
            }
        }
        catch (Exception ex)
        {
            _buscaOk = false;
            _msgBusca = "Falha na consulta. Tente novamente.";
            Console.WriteLine($"[FPD] Buscar contrato: {ex.Message}");
        }
        finally
        {
            _buscando = false;
            InvalidarValidacao();
            StateHasChanged();
        }
    }

    private void PreencherDeContrato(ContratoAfDto c)
    {
        _fpd.ContratoAf           = c.ContratoAf;
        _fpd.Gigov                = c.Gigov;
        _fpd.AgenteFinanceiro     = c.AgenteFinanceiro;
        _fpd.CnpjAgenteFinanceiro = c.CnpjAgenteFinanceiro;
        _fpd.Tomador              = c.Tomador;
        _fpd.CnpjTomador          = c.CnpjTomador;
        _fpd.AgentePromotor       = c.AgentePromotor;
        _fpd.CnpjAgentePromotor   = c.CnpjAgentePromotor;
        _fpd.Programa             = c.Programa;
        _fpd.Ve                   = c.Ve;
        _fpd.CpAtual              = c.CpAtual;
        _fpd.Desembolsado         = c.Desembolsado;
        _fpd.Integralizado        = c.Integralizado;
        _fpd.SaldoDesembolsar     = c.SaldoDesembolsar;
        _fpd.SaldoIntegralizar    = c.SaldoIntegralizar;
        _fpd.PercObra             = c.PercObra;
        _fpd.SituacaoObra         = c.SituacaoObra;
    }

    // ── VALIDAR (lógica na API) ──
    private async Task Validar()
    {
        if (_validando) return;
        _validando = true;
        _status = StatusValidacao.Nenhum;
        _etapas.Clear();
        StateHasChanged();
        try
        {
            var req = MontarRequisicao();
            var resposta = await Http.PostAsJsonAsync("api/fpd/validar", req);
            resposta.EnsureSuccessStatusCode();
            var resultado = await resposta.Content.ReadFromJsonAsync<ValidacaoFpdResultado>() ?? new();

            foreach (var e in resultado.Etapas)
            {
                var etapa = new Etapa { Texto = e.Texto };
                _etapas.Add(etapa);
                StateHasChanged();
                await RolarAoFim();
                await Task.Delay(260);
                etapa.Estado  = e.Ok ? "ok" : "falha";
                etapa.Detalhe = e.Detalhe;
                StateHasChanged();
                await RolarAoFim();
            }
            _status = resultado.Aprovado ? StatusValidacao.Aprovado : StatusValidacao.Reprovado;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[FPD] Erro ao validar: {ex.Message}");
            _etapas.Add(new Etapa { Estado = "falha", Texto = "Falha na consulta ao sistema", Detalhe = "tente novamente" });
            _status = StatusValidacao.Reprovado;
        }
        finally
        {
            _validando = false;
            StateHasChanged();
        }
    }

    private ValidacaoFpdRequest MontarRequisicao() => new()
    {
        Gigov              = _fpd.Gigov,
        ContratoAf         = _fpd.ContratoAf,
        Tomador            = _fpd.Tomador,
        Ve                 = _fpd.Ve,
        ParticipacaoFgts   = _fpd.ParticipacaoFgts,
        Contrapartida      = _fpd.Contrapartida,
        PercObra           = _fpd.PercObra,
        UltimoDesembolso   = _fpd.UltimoDesembolso,
        Funcionalidade     = _fpd.Funcionalidade,
        Conclusao          = _fpd.Conclusao,
        PlacaLocal         = _fpd.PlacaLocal,
        TomadorAdimplente  = _fpd.TomadorAdimplente,
        PromotorAdimplente = _fpd.PromotorAdimplente,
    };

    private async Task RolarAoFim()
    {
        try { await JS.InvokeVoidAsync("sipubScrollFim", _corpoRef); }
        catch { }
    }

    private void InvalidarValidacao()
    {
        if (_status != StatusValidacao.Nenhum || _etapas.Count > 0)
        {
            _status = StatusValidacao.Nenhum;
            _etapas.Clear();
        }
    }

    // Primeiro desembolso não tem "último desembolso" a comparar — força "não" e
    // trava o toggle (some também Funcionalidade/Conclusão). Também não há
    // contrato AF prévio a buscar, então o campo/botão de busca desabilita.
    private void AoMudarPrimeiroDesembolso()
    {
        if (_fpd.PrimeiroDesembolso)
        {
            _fpd.UltimoDesembolso = "nao";
            _fpd.Funcionalidade   = null;
            _fpd.Conclusao        = null;
        }
        InvalidarValidacao();
    }

    private void DefinirTipoDesembolso(string tipo)
    {
        if (_fpd.TipoDesembolso == tipo) return;
        _fpd.TipoDesembolso = tipo;
        InvalidarValidacao();
    }

    private async Task Solicitar()
    {
        if (_status != StatusValidacao.Aprovado || _solicitando) return;
        _solicitando = true;
        try
        {
            // Requisição já pronta com todos os binds (marcado/não marcado) do
            // formulário — falta apenas o endpoint definitivo no servidor.
            var req = MontarRequisicaoSolicitacao();
            var resposta = await Http.PostAsJsonAsync("api/fpd/solicitar", req);
            if (!resposta.IsSuccessStatusCode)
                Console.WriteLine($"[FPD] Endpoint de solicitação ainda não disponível ({(int)resposta.StatusCode}).");
        }
        catch (Exception ex)
        {
            // Endpoint futuro — falha aqui não deve travar o fluxo local.
            Console.WriteLine($"[FPD] Solicitar: {ex.Message}");
        }
        finally
        {
            await AoSolicitar.InvokeAsync(_fpd);
            _solicitando = false;
        }
    }

    private SolicitacaoFpdRequest MontarRequisicaoSolicitacao() => new()
    {
        Solicitante = _fpd.Solicitante, Gigov = _fpd.Gigov, Gestor = _fpd.Gestor,
        IdFpd = _fpd.IdFpd, NumeroFpd = _fpd.NumeroFpd, ContratoAf = _fpd.ContratoAf,
        DataSolicitado = _fpd.DataSolicitado, PrimeiroDesembolso = _fpd.PrimeiroDesembolso,

        AgenteFinanceiro = _fpd.AgenteFinanceiro, CnpjAgenteFinanceiro = _fpd.CnpjAgenteFinanceiro,
        Tomador = _fpd.Tomador, CnpjTomador = _fpd.CnpjTomador,
        AgenteTecnico = _fpd.AgenteTecnico, CnpjAgenteTecnico = _fpd.CnpjAgenteTecnico,
        AgentePromotor = _fpd.AgentePromotor, CnpjAgentePromotor = _fpd.CnpjAgentePromotor,
        Programa = _fpd.Programa,

        UltimoDesembolso = _fpd.UltimoDesembolso, Funcionalidade = _fpd.Funcionalidade, Conclusao = _fpd.Conclusao,
        TomadorAdimplente = _fpd.TomadorAdimplente, PromotorAdimplente = _fpd.PromotorAdimplente,
        RetornoParcial = _fpd.RetornoParcial, PlacaLocal = _fpd.PlacaLocal,
