/* Campos base */
.fpd-campo { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
.fpd-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--ink-500); }
