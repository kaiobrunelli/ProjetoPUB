<div class="overlay-baixa" @onclick="AoCancelar"></div>

<div class="dialog-baixa" @onclick:stopPropagation>

    <div class="dialog-baixa-header">
        <div class="dialog-baixa-icone">
            <i class="bi bi-shield-lock"></i>
        </div>
        <div>
            <div class="dialog-baixa-titulo">Confirmar baixa</div>
            <div class="dialog-baixa-subtitulo">
                @Quantidade @(Quantidade == 1 ? "desembolso selecionado" : "desembolsos selecionados")
            </div>
        </div>
        <button class="dialog-baixa-fechar" @onclick="AoCancelar" disabled="@_processando">
            <i class="bi bi-x-lg"></i>
        </button>
    </div>

    <div class="dialog-baixa-corpo">
        <p class="dialog-baixa-info">
            <i class="bi bi-info-circle"></i>
            Informe sua senha para registrar a baixa. Esta ação será auditada com sua matrícula.
        </p>

        <label class="dialog-baixa-label">Senha</label>
        <input class="dialog-baixa-input @(TemErro ? "invalido" : "")"
               type="password"
               placeholder="••••••••"
               @bind="_senha" @bind:event="oninput"
               @onkeydown="TratarTecla"
               disabled="@_processando" />
        @if (TemErro)
        {
            <span class="dialog-baixa-erro">@_erro</span>
        }
    </div>

    <div class="dialog-baixa-rodape">
        <button class="btn-baixa-cancelar" @onclick="AoCancelar" disabled="@_processando">Cancelar</button>
        <button class="btn-baixa-confirmar" @onclick="Confirmar" disabled="@(_processando || string.IsNullOrEmpty(_senha))">
            @if (_processando)
            {
                <i class="bi bi-arrow-repeat spin"></i>
                <span>Baixando…</span>
            }
            else
            {
                <i class="bi bi-check2-circle"></i>
                <span>Baixar</span>
            }
        </button>
    </div>
</div>

@code {
    [Parameter] public int Quantidade { get; set; }
    [Parameter, EditorRequired] public EventCallback AoCancelar { get; set; }
    [Parameter, EditorRequired] public EventCallback<string> AoConfirmar { get; set; }

    private string _senha = "";
    private string? _erro;
    private bool _processando;

    private bool TemErro => !string.IsNullOrEmpty(_erro);

    private async Task Confirmar()
    {
        if (string.IsNullOrWhiteSpace(_senha))
        {
            _erro = "Informe a senha.";
            return;
        }

        _processando = true;
        _erro = null;
        StateHasChanged();

        await Task.Delay(900);   // simula validação da senha no servidor

        // Mock: senha "1234" falha para demonstrar o caminho de erro
        if (_senha == "1234")
        {
            _erro = "Senha inválida.";
            _processando = false;
            return;
        }

        await AoConfirmar.InvokeAsync(_senha);
    }

    private async Task TratarTecla(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Confirmar();
        else if (e.Key == "Escape") await AoCancelar.InvokeAsync();
    }
}


<style>
.overlay-baixa {
    position: fixed; inset: 0;
    background: rgba(0, 0, 0, .45);
    z-index: 2000;
    animation: fadeIn .15s ease;
}

.dialog-baixa {
    position: fixed;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: min(420px, calc(100vw - 32px));
    background: #fff;
    border: 1px solid var(--ink-100);
    border-radius: var(--radius-xl);
    box-shadow: 0 24px 60px rgba(0, 0, 0, .25);
    z-index: 2001;
    overflow: hidden;
    animation: fadeIn .15s ease;
}

.dialog-baixa-header {
    display: flex; align-items: center; gap: 12px;
    padding: 18px 22px 14px;
    border-bottom: 1px solid var(--ink-100);
    background: var(--ink-50);
}
.dialog-baixa-icone {
    width: 40px; height: 40px;
    background: var(--brand-50);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: var(--brand-700); font-size: 18px; flex-shrink: 0;
}
.dialog-baixa-titulo    { font-size: 15px; font-weight: 600; color: var(--ink-900); }
.dialog-baixa-subtitulo { font-size: 12px; color: var(--ink-500); margin-top: 2px; }
.dialog-baixa-fechar {
    margin-left: auto; color: var(--ink-500); font-size: 15px; padding: 4px;
}
.dialog-baixa-fechar:hover:not(:disabled) { color: var(--ink-900); }

.dialog-baixa-corpo { padding: 20px 22px; }
.dialog-baixa-info {
    font-size: 12px; color: var(--ink-500);
    display: flex; align-items: flex-start; gap: 6px;
    margin: 0 0 16px; line-height: 1.5;
}
.dialog-baixa-info i { margin-top: 2px; flex-shrink: 0; }

.dialog-baixa-label {
    display: block;
    font-size: 10.5px; font-weight: 700; text-transform: uppercase;
    letter-spacing: .08em; color: var(--ink-500); margin-bottom: 5px;
}
.dialog-baixa-input {
    width: 100%;
    height: 38px;
    padding: 0 12px;
    border: 1px solid var(--ink-200);
    border-radius: var(--radius-md);
    font-size: 14px; font-family: inherit;
    letter-spacing: .1em;
}
.dialog-baixa-input:focus {
    outline: none;
    border-color: var(--brand-500);
    box-shadow: 0 0 0 3px rgba(45, 138, 216, .15);
}
.dialog-baixa-input.invalido { border-color: var(--err); background: #FFFAFA; }
.dialog-baixa-erro { font-size: 11px; color: var(--err); display: block; margin-top: 6px; }

.dialog-baixa-rodape {
    display: flex; gap: 10px; justify-content: flex-end;
    padding: 14px 22px 18px;
    background: var(--ink-50);
    border-top: 1px solid var(--ink-100);
}
.btn-baixa-cancelar {
    border: 1px solid var(--ink-200); border-radius: var(--radius-md);
    padding: 8px 16px; font-size: 13px; color: var(--ink-500); background: none;
}
.btn-baixa-cancelar:hover:not(:disabled) { background: var(--ink-100); }
.btn-baixa-confirmar {
    display: flex; align-items: center; gap: 6px;
    background: var(--brand-700); color: #fff;
    border-radius: var(--radius-md); padding: 8px 18px;
    font-size: 13px; font-weight: 600;
    transition: background .15s, opacity .15s;
}
.btn-baixa-confirmar:hover:not(:disabled) { background: var(--brand-800, #004F93); }
.btn-baixa-confirmar:disabled { opacity: .5; cursor: not-allowed; }

.spin { animation: girar .8s linear infinite; display: inline-block; }
</style>
