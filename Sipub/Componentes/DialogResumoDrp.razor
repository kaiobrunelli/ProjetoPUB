@using System.Globalization

@*
   DIALOG RESUMO DRP — modal centrado, em etapas (mesmo padrão de
   PainelPreencherFpdEtapas), 100% somente-leitura: é a checagem final
   antes/depois da baixa.

   3 etapas — optei por 3 em vez de 2 porque Validações (lista com
   comentários) e Histórico (timeline) são conteúdos longos o bastante pra
   não caberem bem numa etapa só sem rolagem excessiva:
   1. Cabeçalho    — dados do desembolso/contrato/valores, sem nada pra rolar.
   2. Validações   — checklist em acordeão (expande por item, não em coluna
      fixa) pra caber sem ocupar muito espaço; aviso quando algum item tem
      comentário registrado.
   3. Histórico    — timeline de toda a atividade do desembolso.

   Ao contrário do PainelPreencherFpdEtapas, aqui todas as etapas são
   clicáveis livremente (sem bloqueio de "avançar só depois de validar") —
   é revisão, não preenchimento.
*@

<div class="overlay-dfp" @onclick="FecharDialog">
    <div class="dfp" @onclick:stopPropagation role="dialog" aria-modal="true">

        @{
            var detalhe   = ServicoMock.ObterDetalheContrato(Desembolso);
            var fin       = detalhe.Financiamento;
            var validacoes = ObterValidacoesEfetivas();
        }

        <!-- ── TOP BAR ── -->
        <div class="dfp-topbar">
            <div class="dfp-id">
                <i class="bi bi-file-text"></i>
                <span class="dfp-id-label">Desembolso ID</span>
                <span class="dfp-id-num">@Desembolso.NumId</span>
            </div>
            <div class="dfp-topbar-right">
                <div class="nav-pill-group">
                    <button class="btn-nav" @onclick="Anterior" disabled="@(!TemAnterior)" title="Anterior">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                    <span class="nav-pos">@(IndiceAtual + 1)/@Todos.Count</span>
                    <button class="btn-nav" @onclick="Proximo" disabled="@(!TemProximo)" title="Próximo">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
                <button class="btn-fechar" @onclick="FecharDialog" title="Fechar (Esc)">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        </div>

        <!-- ═══ STEPPER ═══ -->
        <div class="fpd-stepper">
            @StepHeader(1, "bi-file-earmark-text", "Cabeçalho")
            <div class="fpd-step-linha @(_etapaAtual > 1 ? "concluida" : "")"></div>
            @StepHeader(2, "bi-check2-square", "Validações")
            <div class="fpd-step-linha @(_etapaAtual > 2 ? "concluida" : "")"></div>
            @StepHeader(3, "bi-clock-history", "Histórico")
        </div>

        <!-- ── Corpo ── -->
        @if (_etapaAtual == 1)
        {
            <!-- ═══ ETAPA 1 — CABEÇALHO ═══ -->
            <div class="dfp-header dfp-header-etapa">

                <div class="dfp-titulo-row">
                    <div class="dfp-titulo-left">
                        <div class="dfp-name-row">
                            <h2 class="dfp-mutuario">@Desembolso.Mutuario</h2>
                            <span class="dfp-dsb-id">@Desembolso.Id</span>
                            @if (!string.IsNullOrEmpty(Desembolso.Gigov))
                            {
                                <span class="dfp-gigov">@Desembolso.Gigov</span>
                            }
                        </div>
                        <div class="dfp-meta-row">
                            <PilulhaStatus Status="@Desembolso.Status" Tamanho="sm" />
                            <span class="dfp-prazo-chip">
                                <i class="bi bi-calendar3"></i>
                                Prazo:&nbsp;<strong>@Desembolso.PrazoFinal.ToString("dd MMM", new CultureInfo("pt-BR"))</strong>
                            </span>
                            @if (detalhe.PrimeiroDesembolso)
                            {
                                <span class="dfp-badge-destaque"><i class="bi bi-flag-fill"></i> Primeiro desembolso</span>
                            }
                            <span class="dfp-badge-tipo @(detalhe.TipoDesembolso == "adiantamento" ? "adiantamento" : "")">
                                @(detalhe.TipoDesembolso == "adiantamento" ? "Adiantamento" : "Normal")
                            </span>
                            @if (Analista is not null)
                            {
                                <div class="analista-mini" style="background: @Analista.Cor">@Analista.Iniciais</div>
                                <span class="dfp-analista-nome">@Analista.Nome</span>
                            }
                        </div>
                    </div>
                </div>

                <!-- Dados do contrato (AF, agentes, programa) -->
                <div class="dfp-dados-grid">
                    <div class="dfp-coluna">
                        <div class="dfp-secao-titulo">Contrato AF</div>
                        <div class="dfp-linha">
                            <span class="dfp-rotulo">Contrato</span>
                            <span class="dfp-valor dfp-mono">@Desembolso.Contrato</span>
                        </div>
                        <div class="dfp-linha">
                            <span class="dfp-rotulo">Agente Financeiro</span>
                            <span class="dfp-valor">@detalhe.AgenteFinanceiro</span>
                        </div>
                        <div class="dfp-linha">
                            <span class="dfp-rotulo">Agente Promotor</span>
                            <span class="dfp-valor">@detalhe.AgentePromotor</span>
                        </div>
                        <div class="dfp-linha dfp-linha-last">
                            <span class="dfp-rotulo">Programa</span>
                            <span class="dfp-valor">@fin.Programa</span>
                        </div>
                    </div>

                    <div class="dfp-divisor-v"></div>

                    <div class="dfp-coluna">
                        <div class="dfp-secao-titulo">Financiamento</div>
                        <div class="dfp-linha">
                            <span class="dfp-rotulo">Fase</span>
                            <span class="dfp-valor">@fin.Fase</span>
                        </div>
                        <div class="dfp-linha">
                            <span class="dfp-rotulo">Nº Desembolso</span>
                            <span class="dfp-valor">@fin.NumeroDesembolso</span>
                        </div>
                        <div class="dfp-linha dfp-linha-last">
                            <span class="dfp-rotulo">% Obra concluída (BM)</span>
                            <div class="dfp-obra-wrap">
                                <div class="obra-track">
                                    <div class="obra-fill" style="width: @fin.PercentualObra%"></div>
                                </div>
                                <span class="dfp-valor dfp-mono">@fin.PercentualObra%</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Valores -->
                <div class="dfp-valores">
                    <div class="dfp-secao-titulo">Valores</div>
                    <div class="dfp-linha dfp-linha-destaque">
                        <span class="dfp-rotulo">Valor solicitado (parcela)</span>
                        <span class="dfp-valor dfp-mono dfp-valor-destaque">@ServicoMock.FormatarBRL(Desembolso.Valor)</span>
                    </div>
                    <div class="dfp-linha">
                        <span class="dfp-rotulo">VE (Valor Empréstimo)</span>
                        <span class="dfp-valor dfp-mono">@ServicoMock.FormatarBRL(fin.Ve)</span>
                    </div>
                    <div class="dfp-linha">
                        <span class="dfp-rotulo">Participação FGTS</span>
                        <span class="dfp-valor dfp-mono">@ServicoMock.FormatarBRL(fin.ParticipacaoFgts)</span>
                    </div>
                    <div class="dfp-linha">
                        <span class="dfp-rotulo">Contrapartida</span>
                        <span class="dfp-valor dfp-mono">@ServicoMock.FormatarBRL(fin.Contrapartida)</span>
                    </div>
                    @if (fin.PercGlobal is not null)
                    {
                        <div class="dfp-linha dfp-linha-last">
                            <span class="dfp-rotulo">% Global (FGTS + contrapartida / VE)</span>
                            <span class="dfp-valor dfp-mono">@(fin.PercGlobal.Value.ToString("0.0", new CultureInfo("pt-BR")))%</span>
                        </div>
                    }
                </div>
            </div>
        }
        else if (_etapaAtual == 2)
        {
            <!-- ═══ ETAPA 2 — VALIDAÇÕES (acordeão) ═══
                 Desembolso na DRP já passou pela aprovação — não existe "inválida" nem
                 "a analisar" aqui, então é só a lista, sem agrupar por status. ═══ -->
            <div class="dfp-etapa-validacoes">
                <div class="dfp-etapa-validacoes-topo">
                    <span class="dfp-etapa-validacoes-contagem ok">
                        <i class="bi bi-check-circle-fill"></i> @validacoes.Count validações aprovadas
                    </span>
                    @if (TotalComComentario > 0)
                    {
                        <div class="dfp-resumo-aviso">
                            <i class="bi bi-chat-text-fill"></i>
                            <span><strong>@TotalComComentario</strong> com comentário</span>
                        </div>
                    }
                </div>

                @foreach (var v in validacoes)
                {
                    var chave = $"v{v.Numero}";
                    var aberta = _validacoesAbertas.Contains(chave);
                    var comentarios = ObterComentarios(chave);

                    <div class="dfp-acc @(aberta ? "aberta" : "")">
                        <button class="dfp-acc-header" @onclick="() => AlternarValidacao(chave)">
                            <span class="dfp-acc-num">@v.Numero.ToString().PadLeft(2, '0')</span>
                            <span class="dfp-acc-titulo">@v.Titulo</span>
                            @if (comentarios.Any())
                            {
                                <i class="bi bi-chat-text-fill dfp-acc-comm"></i>
                            }
                            <PilulhaStatus Status="valido" Tamanho="sm" />
                            <i class="bi bi-chevron-down dfp-acc-chevron"></i>
                        </button>
                        <div class="dfp-acc-body">
                            <div class="dfp-acc-inner">
                                <div class="dfp-acc-corpo">
                                    @if (!string.IsNullOrEmpty(v.Detalhe))
                                    {
                                        <p class="dfp-acc-detalhe">@v.Detalhe</p>
                                    }
                                    <FioComentario Comentarios="@comentarios" ApenasLeitura="true" />
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <!-- ═══ ETAPA 3 — HISTÓRICO ═══ -->
            <div class="dfp-corpo">
                <div class="dfp-timeline">
                    @foreach (var evento in MontarTimeline())
                    {
                        <div class="dfp-evento @evento.Tipo">
                            <div class="dfp-evento-ponto"><i class="bi @evento.Icone"></i></div>
                            <div class="dfp-evento-corpo">
                                <div class="dfp-evento-texto">@((MarkupString)evento.Texto)</div>
                                <div class="dfp-evento-quando">@evento.Quando</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- ── Rodapé ── -->
        <div class="dfp-rodape">
            <div class="dfp-rodape-status">
                <i class="bi bi-clipboard-check ok"></i>
                <span>Checagem final — somente visualização</span>
            </div>

            @if (_etapaAtual > 1)
            {
                <button class="btn-fpd-etapa-voltar" @onclick="EtapaAnterior">
                    <i class="bi bi-chevron-left"></i> <span>Etapa anterior</span>
                </button>
            }
            @if (_etapaAtual < 3)
            {
                <button class="btn-fpd-etapa-proxima" @onclick="ProximaEtapa">
                    <span>Próxima etapa</span> <i class="bi bi-chevron-right"></i>
                </button>
            }
            <button class="btn-recusar-cancelar" @onclick="FecharDialog">Fechar</button>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public DesembolsoCAD       Desembolso { get; set; } = null!;
    [Parameter, EditorRequired] public List<DesembolsoCAD> Todos      { get; set; } = [];
    [Parameter] public Funcionario?  Analista  { get; set; }
    [Parameter] public EventCallback AoFechar  { get; set; }
    [Parameter] public EventCallback<string> AoNavegar { get; set; }

    private int _etapaAtual = 1;
    private readonly HashSet<string> _validacoesAbertas = [];
    private readonly Dictionary<string, List<Comentario>> _comentarios = new();

    protected override void OnInitialized()
    {
        foreach (var v in ServicoMock.ObterValidacoesFpd(Desembolso.Id).Where(v => v.ComentarioPreenchido is not null))
        {
            var chave = $"v{v.Numero}";
            _comentarios[chave] = [v.ComentarioPreenchido!];
            _validacoesAbertas.Add(chave);   // já expande quem tem comentário, pra revisão ficar visível de cara
        }
    }

    private int IndiceAtual  => Todos.FindIndex(d => d.Id == Desembolso.Id);
    private bool TemAnterior => IndiceAtual > 0;
    private bool TemProximo  => IndiceAtual < Todos.Count - 1;

    private async Task Anterior() { if (TemAnterior) await AoNavegar.InvokeAsync(Todos[IndiceAtual - 1].Id); }
    private async Task Proximo()  { if (TemProximo)  await AoNavegar.InvokeAsync(Todos[IndiceAtual + 1].Id); }
    private async Task FecharDialog() => await AoFechar.InvokeAsync();

    // ── Stepper — livre em qualquer direção (é revisão, não preenchimento) ──
    private RenderFragment StepHeader(int numero, string icone, string titulo) =>
        @<button type="button" class="fpd-step @(EstadoEtapa(numero))" @onclick="() => _etapaAtual = numero">
            <span class="fpd-step-num">
                @if (numero < _etapaAtual) { <i class="bi bi-check-lg"></i> } else { @numero }
            </span>
            <span class="fpd-step-titulo">@titulo</span>
        </button>;

    private string EstadoEtapa(int numero) =>
        numero == _etapaAtual ? "atual" : numero < _etapaAtual ? "concluida" : "";

    private void ProximaEtapa()  { if (_etapaAtual < 3) _etapaAtual++; }
    private void EtapaAnterior() { if (_etapaAtual > 1) _etapaAtual--; }

    private List<Comentario> ObterComentarios(string chave) => _comentarios.TryGetValue(chave, out var l) ? l : [];

    private int TotalComComentario => ObterValidacoesEfetivas().Count(v => ObterComentarios($"v{v.Numero}").Any());

    private void AlternarValidacao(string chave)
    {
        if (!_validacoesAbertas.Add(chave))
            _validacoesAbertas.Remove(chave);
    }

    // ── Checklist plano, mesma regra do dialog de desembolso: comentário
    // positivo promove o item de "em análise"/"inválida" para "aprovada". ──
    private List<Validacao> ObterValidacoesEfetivas()
    {
        var validacoes = ServicoMock.ObterValidacoesFpd(Desembolso.Id);
        return validacoes.Select(v =>
        {
            var chave = $"v{v.Numero}";
            var status = v.Status;
            if (v.Status is "invalido" or "pendente"
                && _comentarios.TryGetValue(chave, out var comms)
                && comms.Any(c => c.Tipo == "positivo"))
            {
                status = "valido";
            }

            return new Validacao
            {
                Numero = v.Numero, Titulo = v.Titulo, Resultado = v.Resultado,
                Status = status, Icone = v.Icone, Detalhe = v.Detalhe,
                ComentarioPreenchido = v.ComentarioPreenchido
            };
        }).ToList();
    }

    // ── Histórico: timeline com todos os comentários de todas as validações ──
    private record EventoTimeline(string Icone, string Texto, string Quando, string Tipo);

    private List<EventoTimeline> MontarTimeline()
    {
        var cultura = new CultureInfo("pt-BR");
        var criacao = Desembolso.PrazoFinal.AddDays(-21);
        var eventos = new List<EventoTimeline>
        {
            new("bi-inbox", $"Desembolso <strong>{Desembolso.Id}</strong> recebido para análise",
                criacao.ToString("dd MMM yyyy", cultura), "neutro"),
        };

        if (Analista is not null)
            eventos.Add(new("bi-person-check", $"Atribuído a <strong>{Analista.Nome}</strong>",
                criacao.AddDays(1).ToString("dd MMM yyyy", cultura), "info"));

        foreach (var (chave, lista) in _comentarios)
            foreach (var c in lista)
                eventos.Add(new(
                    c.Tipo == "positivo" ? "bi-check-circle" : c.Tipo == "negativo" ? "bi-x-circle" : "bi-chat-text",
                    $"<strong>{c.Autor}</strong> comentou em <strong>{chave.ToUpper()}</strong>: “{c.Texto}”",
                    ServicoMock.FormatarTempo(c.Timestamp),
                    c.Tipo == "negativo" ? "falha" : c.Tipo == "positivo" ? "ok" : "info"));

        eventos.Add(Desembolso.Status switch
        {
            "aprovado" => new("bi-patch-check", "Desembolso <strong>aprovado</strong>",
                DateTime.Today.ToString("dd MMM yyyy", cultura), "ok"),
            "pendencia" => new("bi-exclamation-triangle", "Pendências identificadas — <strong>aguardando tratativa</strong>",
                "agora", "falha"),
            _ => new("bi-hourglass-split", "Em análise — <strong>aguardando decisão</strong>", "agora", "neutro")
        });

        return eventos;
    }
}

<style>
.overlay-dfp {
    position: fixed; inset: 0;
    background: rgba(34,41,46,.45);
    z-index: 500;
    display: flex; align-items: flex-start; justify-content: center;
    padding: 16px; overflow-y: auto;
    animation: fadeIn .18s ease;
}

.dfp {
    position: relative;
    width: 100%; max-width: 960px;
    background: #fff;
    border-radius: var(--radius-xl, 10px);
    box-shadow: var(--shadow-pop);
    display: flex; flex-direction: column;
    animation: popIn .22s ease;
    max-height: calc(100vh - 32px);
    overflow: hidden;
    margin: auto;
}

/* ── Top bar ── */
.dfp-topbar { display: flex; align-items: center; gap: 8px; padding: 9px 20px; border-bottom: 1px solid var(--ink-100); flex-shrink: 0; background: #fff; }
.dfp-id { display: flex; align-items: center; gap: 5px; flex: 1; }
.dfp-id i { font-size: 11px; color: #9EB2BB; }
.dfp-id-label { font-size: 11.5px; font-weight: 600; color: var(--ink-600); }
.dfp-id-num { font-family: monospace; font-size: 11.5px; font-weight: 600; color: var(--ink-700); }
.dfp-topbar-right { display: flex; align-items: center; gap: 6px; }

.nav-pill-group { display: inline-flex; align-items: center; gap: 0; border: 1px solid var(--ink-100); border-radius: var(--radius-md); background: #FAFBFD; padding: 2px; }
.btn-nav { width: 24px; height: 24px; border-radius: 5px; background: transparent; border: none; color: #64747A; font-size: 11px; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: background .12s; }
.btn-nav:hover:not(:disabled) { background: #fff; }
.btn-nav:disabled { opacity: .3; cursor: not-allowed; }
.nav-pos { padding: 0 6px; font-size: 10.5px; font-weight: 700; color: var(--ink-600); font-variant-numeric: tabular-nums; }

.btn-fechar { width: 28px; height: 28px; border-radius: var(--radius-md); border: 1px solid var(--ink-100); color: #64747A; font-size: 12px; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: background .12s; }
.btn-fechar:hover { background: var(--ink-50); }

/* ── Stepper (mesmo padrão do PainelPreencherFpdEtapas) ── */
.fpd-stepper { display: flex; align-items: center; padding: 14px 24px; background: var(--ink-50); border-bottom: 1px solid var(--ink-100); flex-shrink: 0; }
.fpd-step {
    display: flex; align-items: center; gap: 8px; background: transparent; border: none;
    padding: 4px 6px; border-radius: var(--radius-md); cursor: pointer; font-family: inherit;
}
.fpd-step-num {
    width: 24px; height: 24px; border-radius: 50%; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 700; background: var(--ink-200); color: var(--ink-600, var(--ink-700));
    transition: background .15s, color .15s;
}
.fpd-step-titulo { font-size: 12.5px; font-weight: 600; color: var(--ink-500); white-space: nowrap; transition: color .15s; }
.fpd-step.atual .fpd-step-num { background: var(--brand-700); color: #fff; }
.fpd-step.atual .fpd-step-titulo { color: var(--brand-800); }
.fpd-step.concluida .fpd-step-num { background: var(--ok-bg); color: var(--ok); }
.fpd-step.concluida .fpd-step-titulo { color: var(--ink-700); }
.fpd-step.concluida:hover .fpd-step-titulo { color: var(--brand-700); }
.fpd-step-linha { flex: 1; height: 2px; background: var(--ink-200); margin: 0 4px; transition: background .2s; }
.fpd-step-linha.concluida { background: var(--ok); }

/* ── Cabeçalho (etapa 1) ── */
.dfp-header { background: #F8FAFC; flex-shrink: 0; overflow-y: auto; }
.dfp-header-etapa { flex: 1; }

.dfp-titulo-row { display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; padding: 14px 24px 12px; border-bottom: 1px solid var(--ink-100); }
.dfp-titulo-left { flex: 1; min-width: 0; }
.dfp-name-row { display: flex; align-items: baseline; gap: 10px; margin-bottom: 8px; flex-wrap: wrap; }
.dfp-mutuario { font-size: 20px; font-weight: 800; line-height: 1.2; letter-spacing: -.02em; color: var(--ink-900); margin: 0; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.dfp-dsb-id { font-family: monospace; font-size: 11px; font-weight: 700; color: var(--ink-400); flex-shrink: 0; }
.dfp-gigov { display: inline-flex; align-items: center; border: 1px solid var(--ink-100); background: var(--ink-50); border-radius: 6px; padding: 1px 6px; font-family: monospace; font-size: 10px; font-weight: 700; color: var(--ink-600); flex-shrink: 0; }

.dfp-meta-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.dfp-prazo-chip { display: inline-flex; align-items: center; gap: 5px; border: 1px solid var(--brand-200); background: var(--brand-50); border-radius: var(--radius-full); padding: 4px 10px; font-size: 10.5px; font-weight: 600; color: var(--brand-800, #004F93); }
.dfp-prazo-chip i { font-size: 10px; color: #005CA9; }
.dfp-prazo-chip strong { font-weight: 700; }

.dfp-badge-destaque { display: inline-flex; align-items: center; gap: 5px; border: 1px solid var(--brand-200); background: var(--brand-700); border-radius: var(--radius-full); padding: 4px 10px; font-size: 10.5px; font-weight: 700; color: #fff; }

.dfp-badge-tipo { display: inline-flex; align-items: center; border: 1px solid var(--ink-200); background: #fff; border-radius: var(--radius-full); padding: 4px 10px; font-size: 10.5px; font-weight: 700; color: var(--ink-700); }
.dfp-badge-tipo.adiantamento { border-color: #F5D0A0; background: var(--warn-bg, #FFEFD6); color: #9A5B00; }

.analista-mini { width: 20px; height: 20px; border-radius: 50%; color: #fff; font-size: 8.5px; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.dfp-analista-nome { font-size: 12px; font-weight: 500; color: var(--ink-600); }

