@page "/apresentacao"
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Apresentação — SIPUB</PageTitle>

<!-- ══ HERO ══════════════════════════════════════════════════════ -->
<section class="apres-hero reveal">
    <div class="apres-hero-inner">

        <div class="apres-badge">
            <i class="bi bi-easel2"></i>
            SIPUB &middot; Apresentação Consolidada
        </div>

        <h1 class="apres-hero-titulo">
            Panorama de <span class="apres-hero-destaque">Desembolsos</span>
        </h1>

        <p class="apres-hero-periodo">
            @DateTime.Now.ToString("MMMM 'de' yyyy", new System.Globalization.CultureInfo("pt-BR"))
            &nbsp;&middot;&nbsp;
            @_dados.Count @(_dados.Count == 1 ? "contrato" : "contratos") analisados
            @if (!string.IsNullOrEmpty(Filtro) && Filtro != "geral")
            {
                <span class="apres-hero-filtro-badge">Filtro: @_filtroLabel</span>
            }
        </p>

        <!-- Número principal -->
        <div class="apres-hero-valor-bloco">
            <span class="apres-hero-valor-label">Volume Total Consolidado</span>
            <span class="apres-hero-valor-num"
                  data-target="@((double)_valorTotal)"
                  data-money="true">R$&nbsp;0</span>
        </div>

        <!-- Mini linha de stats -->
        <div class="apres-hero-mini">
            <div class="apres-hero-mini-item">
                <span class="apres-hero-mini-num" data-target="@_qtdAprovados">0</span>
                <span class="apres-hero-mini-label">Aprovados</span>
            </div>
            <div class="apres-hero-mini-sep"></div>
            <div class="apres-hero-mini-item">
                <span class="apres-hero-mini-num" data-target="@_qtdPendentes">0</span>
                <span class="apres-hero-mini-label">Em Análise</span>
            </div>
            <div class="apres-hero-mini-sep"></div>
            <div class="apres-hero-mini-item">
                <span class="apres-hero-mini-num" data-target="@_qtdInvalidos">0</span>
                <span class="apres-hero-mini-label">Com Pendência</span>
            </div>
            <div class="apres-hero-mini-sep"></div>
            <div class="apres-hero-mini-item">
                <span class="apres-hero-mini-num"
                      data-target="@((double)_taxaAprovacao)"
                      data-percent="true">0%</span>
                <span class="apres-hero-mini-label">Taxa de Aprovação</span>
            </div>
        </div>

    </div>

    <div class="apres-scroll-hint">
        <i class="bi bi-chevron-down"></i>
    </div>
</section>

<!-- ══ DISTRIBUIÇÃO POR SITUAÇÃO ══════════════════════════════════ -->
<section class="apres-secao">
    <div class="apres-container">

        <div class="apres-secao-header reveal">
            <div class="apres-secao-tag">Visão Geral</div>
            <h2 class="apres-secao-titulo">Distribuição por Situação</h2>
            <p class="apres-secao-sub">Como os contratos estão distribuídos entre os estágios de análise</p>
        </div>

        <div class="apres-status-grid">

            <!-- Aprovados -->
            <div class="apres-status-card reveal" style="--delay:0ms">
                <div class="apres-status-card-topo">
                    <div class="apres-status-icone" style="background:#E0F2E7;color:#1A7A4A">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>
                    <div>
                        <div class="apres-status-nome">Aprovados</div>
                        <div class="apres-status-num" data-target="@_qtdAprovados">0</div>
                    </div>
                </div>
                <div class="apres-status-valor">@ServicoMock.FormatarBRL(_valorAprovado)</div>
                <div class="apres-barra-track">
                    <div class="barra-fill barra-ok"
                         data-width="@(PercCss(_valorAprovado))"
                         style="width:0%"></div>
                </div>
                <div class="apres-status-pct">@FormatarPct(_valorAprovado) do volume total</div>
            </div>

            <!-- Em Análise -->
            <div class="apres-status-card reveal" style="--delay:100ms">
                <div class="apres-status-card-topo">
                    <div class="apres-status-icone" style="background:#FFEFD6;color:#D87B00">
                        <i class="bi bi-clock-fill"></i>
                    </div>
                    <div>
                        <div class="apres-status-nome">Em Análise</div>
                        <div class="apres-status-num" data-target="@_qtdPendentes">0</div>
                    </div>
                </div>
                <div class="apres-status-valor">@ServicoMock.FormatarBRL(_valorPendente)</div>
                <div class="apres-barra-track">
                    <div class="barra-fill barra-warn"
                         data-width="@(PercCss(_valorPendente))"
                         style="width:0%"></div>
                </div>
                <div class="apres-status-pct">@FormatarPct(_valorPendente) do volume total</div>
            </div>

            <!-- Com Pendência -->
            <div class="apres-status-card reveal" style="--delay:200ms">
                <div class="apres-status-card-topo">
                    <div class="apres-status-icone" style="background:#FCE6E3;color:#C0392B">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                    </div>
                    <div>
                        <div class="apres-status-nome">Com Pendência</div>
                        <div class="apres-status-num" data-target="@_qtdInvalidos">0</div>
                    </div>
                </div>
                <div class="apres-status-valor">@ServicoMock.FormatarBRL(_valorInvalido)</div>
                <div class="apres-barra-track">
                    <div class="barra-fill barra-err"
                         data-width="@(PercCss(_valorInvalido))"
                         style="width:0%"></div>
                </div>
                <div class="apres-status-pct">@FormatarPct(_valorInvalido) do volume total</div>
            </div>

        </div>
    </div>
</section>

<!-- ══ POR AGÊNCIA (GIGOV) ════════════════════════════════════════ -->
<section class="apres-secao apres-secao-alt">
    <div class="apres-container">

        <div class="apres-secao-header reveal">
            <div class="apres-secao-tag">Distribuição Regional</div>
            <h2 class="apres-secao-titulo">Por Agência (GIGOV)</h2>
            <p class="apres-secao-sub">Volume financeiro e quantidade de contratos por agência gestora</p>
        </div>

        <div class="apres-gigov-lista reveal">
            @foreach (var item in _porGigov)
            {
                var pct = _valorTotal > 0
                    ? ((double)(item.Valor / _valorTotal * 100)).ToString("F1", System.Globalization.CultureInfo.InvariantCulture)
                    : "0.0";
                var pctBr = _valorTotal > 0
                    ? ((double)(item.Valor / _valorTotal * 100)).ToString("F1", new System.Globalization.CultureInfo("pt-BR"))
                    : "0,0";

                <div class="apres-gigov-item">
                    <div class="apres-gigov-header">
                        <div class="apres-gigov-nome">
                            <span class="apres-gigov-badge">@item.Gigov</span>
                            <span class="apres-gigov-count">
                                @item.Count @(item.Count == 1 ? "contrato" : "contratos")
                            </span>
                        </div>
                        <div class="apres-gigov-valor">@ServicoMock.FormatarBRL(item.Valor)</div>
                    </div>
                    <div class="apres-barra-track">
                        <div class="barra-fill barra-brand"
                             data-width="@(pct)%"
                             style="width:0%"></div>
                    </div>
                    <div class="apres-gigov-pct">@pctBr% do volume</div>
                </div>
            }
        </div>

    </div>
</section>

<!-- ══ POR PROGRAMA ═══════════════════════════════════════════════ -->
@if (_porPrograma.Count > 0)
{
    <section class="apres-secao">
        <div class="apres-container">

            <div class="apres-secao-header reveal">
                <div class="apres-secao-tag">Linhas de Crédito</div>
                <h2 class="apres-secao-titulo">Por Programa</h2>
                <p class="apres-secao-sub">Concentração de contratos por programa de financiamento</p>
            </div>

            <div class="apres-prog-grid">
                @foreach (var item in _porPrograma)
                {
                    var pct  = _valorTotal > 0 ? item.Valor / _valorTotal * 100 : 0;
                    var pctCss = _valorTotal > 0
                        ? ((double)(item.Valor / _valorTotal * 100)).ToString("F1", System.Globalization.CultureInfo.InvariantCulture)
                        : "0.0";
                    var pctBr  = pct.ToString("F0", new System.Globalization.CultureInfo("pt-BR"));

                    <div class="apres-prog-card reveal">
                        <div class="apres-prog-icone"><i class="bi bi-building-fill"></i></div>
                        <div class="apres-prog-nome">@item.Programa</div>
                        <div class="apres-prog-valor"
                             data-target="@((double)item.Valor)"
                             data-money="true">R$&nbsp;0</div>
                        <div class="apres-prog-meta">
                            <span>@item.Count @(item.Count == 1 ? "contrato" : "contratos")</span>
                            <span class="apres-prog-pct">@pctBr%</span>
                        </div>
                        <div class="apres-barra-track" style="margin-top:10px">
                            <div class="barra-fill barra-brand"
                                 data-width="@(pctCss)%"
                                 style="width:0%"></div>
                        </div>
                    </div>
                }
            </div>

        </div>
    </section>
}

<!-- ══ INSIGHTS ══════════════════════════════════════════════════ -->
<section class="apres-secao apres-secao-alt">
    <div class="apres-container">

        <div class="apres-secao-header reveal">
            <div class="apres-secao-tag">Destaques</div>
            <h2 class="apres-secao-titulo">Principais Insights</h2>
        </div>

        <div class="apres-insights-grid">

            <div class="apres-insight-card reveal" style="--delay:0ms">
                <div class="apres-insight-icone" style="background:#EBF5FF;color:#005CA9">
                    <i class="bi bi-trophy-fill"></i>
                </div>
                <div class="apres-insight-corpo">
                    <div class="apres-insight-titulo">Maior Contrato</div>
                    <div class="apres-insight-texto">
                        @_maiorMutuario — @ServicoMock.FormatarBRL(_maiorValor)
                    </div>
                </div>
            </div>

            <div class="apres-insight-card reveal" style="--delay:80ms">
                <div class="apres-insight-icone" style="background:#E0F2E7;color:#1A7A4A">
                    <i class="bi bi-patch-check-fill"></i>
                </div>
                <div class="apres-insight-corpo">
                    <div class="apres-insight-titulo">Conformidade de Validações</div>
                    <div class="apres-insight-texto">
                        @_totalValidacoesOk de @_totalValidacoes validações aprovadas
                        (@(_totalValidacoes > 0
                            ? ((decimal)_totalValidacoesOk / _totalValidacoes * 100).ToString("F0", new System.Globalization.CultureInfo("pt-BR"))
                            : "0")%)
                    </div>
                </div>
            </div>

            <div class="apres-insight-card reveal" style="--delay:160ms">
                <div class="apres-insight-icone" style="background:#FFEFD6;color:#D87B00">
                    <i class="bi bi-clock-history"></i>
                </div>
                <div class="apres-insight-corpo">
                    <div class="apres-insight-titulo">Aguardando Revisão</div>
                    <div class="apres-insight-texto">
                        @ServicoMock.FormatarBRL(_valorPendente) em
                        @_qtdPendentes @(_qtdPendentes == 1 ? "contrato pendente" : "contratos pendentes")
                        de análise
                    </div>
                </div>
            </div>

            <div class="apres-insight-card reveal" style="--delay:240ms">
                <div class="apres-insight-icone" style="background:#FCE6E3;color:#C0392B">
                    <i class="bi bi-exclamation-diamond-fill"></i>
                </div>
                <div class="apres-insight-corpo">
                    <div class="apres-insight-titulo">Pendências Críticas</div>
                    <div class="apres-insight-texto">
                        @_qtdInvalidos @(_qtdInvalidos == 1 ? "contrato requer" : "contratos requerem")
                        ação imediata (@ServicoMock.FormatarBRL(_valorInvalido))
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- ══ CTA ════════════════════════════════════════════════════════ -->
<section class="apres-cta reveal">
    <div class="apres-container" style="text-align:center">
        <div class="apres-cta-rotulo">Dados referentes ao ciclo de análise atual</div>
        <button class="btn-voltar" @onclick='() => Nav.NavigateTo("/cad")'>
            <i class="bi bi-arrow-left"></i>
            Voltar para Análise
        </button>
        <div class="apres-cta-data">
            Gerado em @DateTime.Now.ToString("dd/MM/yyyy 'às' HH:mm")
        </div>
    </div>
</section>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? Filtro { get; set; }

    private List<DesembolsoCAD> _dados        = new();
    private decimal _valorTotal;
    private int     _qtdAprovados;
    private int     _qtdPendentes;
    private int     _qtdInvalidos;
    private decimal _taxaAprovacao;
    private decimal _valorAprovado;
    private decimal _valorPendente;
    private decimal _valorInvalido;
    private decimal _maiorValor;
    private string  _maiorMutuario         = "";
    private int     _totalValidacoesOk;
    private int     _totalValidacoes;

    private List<(string Gigov, int Count, decimal Valor)>    _porGigov    = new();
    private List<(string Programa, int Count, decimal Valor)> _porPrograma = new();

    private string _filtroLabel => Filtro switch {
        "invalidos" => "Inválidos",
        "pendentes" => "Em Análise",
        "validos"   => "Aprovados",
        "agendado"  => "Agendados",
        _           => "Geral"
    };

    protected override void OnInitialized()
    {
        var todos = ServicoMock.ObterDesembolsos();
        _dados = Filtro switch {
            "invalidos" => todos.Where(d => d.Status == "pendencia").ToList(),
            "pendentes" => todos.Where(d => d.Status == "pendente").ToList(),
            "validos"   => todos.Where(d => d.Status == "aprovado").ToList(),
            "agendado"  => todos.Where(d => d.Status == "agendado").ToList(),
            _           => todos
        };

        _valorTotal    = _dados.Sum(d => d.Valor);
        _qtdAprovados  = _dados.Count(d => d.Status == "aprovado");
        _qtdPendentes  = _dados.Count(d => d.Status == "pendente");
        _qtdInvalidos  = _dados.Count(d => d.Status == "pendencia");
        _taxaAprovacao = _dados.Count > 0
            ? Math.Round((decimal)_qtdAprovados / _dados.Count * 100, 1)
            : 0;
        _valorAprovado = _dados.Where(d => d.Status == "aprovado").Sum(d => d.Valor);
        _valorPendente = _dados.Where(d => d.Status == "pendente").Sum(d => d.Valor);
        _valorInvalido = _dados.Where(d => d.Status == "pendencia").Sum(d => d.Valor);

        var maior  = _dados.OrderByDescending(d => d.Valor).FirstOrDefault();
        _maiorValor    = maior?.Valor ?? 0;
        _maiorMutuario = maior?.Mutuario ?? "";

        _totalValidacoesOk = _dados.Sum(d => d.ValidacoesOk);
        _totalValidacoes   = _dados.Sum(d => d.ValidacoesTotal);

        _porGigov = _dados
            .GroupBy(d => d.Gigov)
            .Select(g => (Gigov: g.Key, Count: g.Count(), Valor: g.Sum(d => d.Valor)))
            .OrderByDescending(x => x.Valor)
            .ToList();

        _porPrograma = _dados
            .Select(d => new { D = d, Det = ServicoMock.ObterDetalheContrato(d) })
            .GroupBy(x => x.Det.Financiamento.Programa)
            .Select(g => (Programa: g.Key, Count: g.Count(), Valor: g.Sum(x => x.D.Valor)))
            .OrderByDescending(x => x.Valor)
            .ToList();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("ApresentacaoJS.inicializar");
    }

    private string PercCss(decimal valor) =>
        _valorTotal > 0
            ? ((double)(valor / _valorTotal * 100)).ToString("F1", System.Globalization.CultureInfo.InvariantCulture) + "%"
            : "0%";

    private string FormatarPct(decimal valor) =>
        _valorTotal > 0
            ? ((double)(valor / _valorTotal * 100)).ToString("F0", new System.Globalization.CultureInfo("pt-BR")) + "%"
            : "0%";
}


<style>
/* ══════════════════════════════════════════════
   HERO
   ══════════════════════════════════════════════ */
.apres-hero {
    position: relative;
    background: linear-gradient(135deg, #002A4D 0%, #00437A 60%, #005CA9 100%);
    min-height: calc(100vh - var(--topbar-h));
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80px 24px 64px;
    text-align: center;
    overflow: hidden;
}

/* Grid decorativo */
.apres-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
        linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
}

.apres-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 760px;
    width: 100%;
}

.apres-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255,255,255,.1);
    border: 1px solid rgba(255,255,255,.15);
    color: rgba(255,255,255,.85);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: var(--radius-full);
    margin-bottom: 28px;
}

.apres-hero-titulo {
    font-size: 56px;
    font-weight: 800;
    color: #fff;
    line-height: 1.08;
    letter-spacing: -.03em;
    margin-bottom: 16px;
}

.apres-hero-destaque {
    background: linear-gradient(90deg, #6DBAFA, #A0D2FC);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.apres-hero-periodo {
    color: rgba(255,255,255,.6);
    font-size: 14px;
    margin-bottom: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
}

.apres-hero-filtro-badge {
    background: rgba(109,186,250,.2);
    color: #A0D2FC;
    padding: 2px 10px;
    border-radius: var(--radius-full);
    font-size: 11px;
    font-weight: 600;
}

/* Bloco do valor principal */
.apres-hero-valor-bloco {
    background: rgba(255,255,255,.08);
    border: 1px solid rgba(255,255,255,.12);
    border-radius: var(--radius-xl);
    padding: 28px 48px;
    margin-bottom: 48px;
    backdrop-filter: blur(6px);
}

.apres-hero-valor-label {
    display: block;
    color: rgba(255,255,255,.55);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .07em;
    text-transform: uppercase;
    margin-bottom: 10px;
}

.apres-hero-valor-num {
    display: block;
    font-size: 60px;
    font-weight: 800;
    color: #fff;
    letter-spacing: -.04em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
}

/* Mini linha de números */
.apres-hero-mini {
    display: flex;
    align-items: center;
    justify-content: center;
}

.apres-hero-mini-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 32px;
}

.apres-hero-mini-sep {
    width: 1px;
    height: 40px;
    background: rgba(255,255,255,.15);
}

.apres-hero-mini-num {
    font-size: 30px;
    font-weight: 700;
    color: #fff;
    font-variant-numeric: tabular-nums;
    line-height: 1;
}

.apres-hero-mini-label {
    font-size: 11px;
    color: rgba(255,255,255,.5);
    font-weight: 500;
    letter-spacing: .04em;
    margin-top: 4px;
}

/* Indicador de scroll */
.apres-scroll-hint {
    position: absolute;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255,255,255,.35);
    font-size: 22px;
    animation: apres-bounce 2s ease-in-out infinite;
}

@@keyframes apres-bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(8px); }
}

/* ══════════════════════════════════════════════
   REVEAL ANIMATION
   ══════════════════════════════════════════════ */
.reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity .65s ease, transform .65s ease;
    transition-delay: var(--delay, 0ms);
}

.reveal.visivel {
    opacity: 1;
    transform: none;
}

/* Hero sempre visível (sem delay de scroll) */
.apres-hero.reveal {
    opacity: 1;
    transform: none;
}

/* ══════════════════════════════════════════════
   ESTRUTURA DE SEÇÕES
   ══════════════════════════════════════════════ */
.apres-secao {
    padding: 88px 0;
    background: #fff;
}

.apres-secao-alt {
    background: var(--ink-50);
}

.apres-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 32px;
}

.apres-secao-header {
    text-align: center;
    margin-bottom: 52px;
}

.apres-secao-tag {
    display: inline-block;
    color: var(--brand-700);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    margin-bottom: 10px;
}

.apres-secao-titulo {
    font-size: 34px;
    font-weight: 800;
    color: var(--ink-900);
    letter-spacing: -.025em;
    margin-bottom: 10px;
}

.apres-secao-sub {
    color: var(--ink-500);
    font-size: 14px;
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.6;
}

/* ══════════════════════════════════════════════
   BARRAS COMPARTILHADAS
   ══════════════════════════════════════════════ */
.apres-barra-track {
    height: 6px;
    background: var(--ink-100);
    border-radius: var(--radius-full);
    overflow: hidden;
    margin-bottom: 6px;
}

.barra-fill {
    height: 100%;
    border-radius: var(--radius-full);
    transition: width 1.2s cubic-bezier(.4,0,.2,1);
}

.barra-ok    { background: #1A7A4A; }
.barra-warn  { background: #D87B00; }
.barra-err   { background: #C0392B; }
.barra-brand { background: var(--brand-700); }

/* ══════════════════════════════════════════════
   CARDS DE STATUS
