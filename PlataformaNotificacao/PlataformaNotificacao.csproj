<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <!-- EF Core para DbSet e métodos de consulta.
         Sem FrameworkReference AspNetCore: o Hub/IHubContext moram no Server,
         permitindo que este módulo seja referenciado também pelo front (WASM). -->
    <PackageReference Include="Microsoft.EntityFrameworkCore" Version="8.0.27" />
  </ItemGroup>

</Project>
