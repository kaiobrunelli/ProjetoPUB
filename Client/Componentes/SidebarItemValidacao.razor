<button class="sidebar-item @(Selecionado ? "sidebar-item-ativo" : "")"
        @onclick="AoSelecionar">
    <span class="sidebar-ponto sidebar-ponto-@Validacao.Status"></span>
    <span class="sidebar-num-item">@Validacao.Numero.ToString().PadLeft(2, '0')</span>
    <span class="sidebar-titulo">@Validacao.Titulo</span>
    @if (ContadorComentarios > 0)
    {
        <span class="sidebar-comms">
            <i class="bi bi-chat-text-fill"></i>@ContadorComentarios
        </span>
    }
</button>

@code {
    [Parameter, EditorRequired] public Validacao  Validacao           { get; set; } = null!;
    [Parameter] public bool               Selecionado         { get; set; }
    [Parameter] public int                ContadorComentarios { get; set; }
    [Parameter] public EventCallback      AoSelecionar        { get; set; }
}


<style>
.sidebar-item {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    padding: 8px 10px;
    border-radius: var(--radius-lg);
    text-align: left;
    background: transparent;
    border: 1px solid transparent;
    transition: background .12s, box-shadow .12s, border-color .12s;
    cursor: pointer;
    font-size: 12.5px;
    font-weight: 500;
    color: var(--ink-700);
}
.sidebar-item:hover {
    background: rgba(255,255,255,.7);
    border-color: var(--ink-100);
}

/* Item selecionado — card branco elevado */
.sidebar-item-ativo {
    background: #fff !important;
    border-color: var(--ink-100) !important;
    box-shadow: var(--shadow-card);
    color: var(--ink-900);
    font-weight: 600;
}

/* Dot colorido por status */
.sidebar-ponto {
    width: 8px; height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
}
.sidebar-ponto-valido   { background: var(--ok); }
.sidebar-ponto-invalido { background: var(--err); }

/* Número da validação */
.sidebar-num-item {
    flex-shrink: 0;
    font-family: monospace;
    font-size: 10.5px;
    font-weight: 700;
    color: var(--ink-400);
    min-width: 20px;
}

/* Título — truncado */
.sidebar-titulo {
    flex: 1;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

/* Badge de comentários */
.sidebar-comms {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    font-size: 10px;
    font-weight: 700;
    color: var(--ink-500);
    background: var(--ink-100);
    border-radius: var(--radius-full);
    padding: 1px 6px;
    flex-shrink: 0;
}
.sidebar-comms i { font-size: 9px; }
</style>
