@using System.Globalization
@using System.Net.Http.Json
@using PlataformaNotificacao.Domain
@using PlataformaNotificacao.Domain.DTO
@using PlataformaNotificacao.Domain.Enum
@inject HttpClient Http
@inject IJSRuntime JS
@inject ServicoUsuario ServicoUsuario

@* FPD-AF — mesmo formulário do PainelPreencherFpd, só que dividido em 3 etapas
   guiadas (Dados do contrato → Verificações → Valores) com um stepper no topo.
   Validar/Solicitar só aparecem na última etapa. Lógica de domínio idêntica —
   duplicada aqui de propósito para o dialog "árvore única" continuar existindo
   sem depender desta variante. *@

<div class="overlay-fpd" @onclick="AoVoltar"></div>

<div class="dialog-fpd" @onclick:stopPropagation>

    <div class="dialog-fpd-header">
        <div class="dialog-fpd-icone"><i class="bi bi-clipboard-plus"></i></div>
        <div>
            <div class="dialog-fpd-titulo">Preencher FPD-AF</div>
            <div class="dialog-fpd-subtitulo">Ficha de Previsão de Desembolso · em etapas</div>
        </div>
        <button class="dialog-fpd-fechar" @onclick="AoVoltar" title="Fechar"><i class="bi bi-x-lg"></i></button>
    </div>

    <!-- ═══ STEPPER ═══ -->
    <div class="fpd-stepper">
        @StepHeader(1, "bi-file-earmark-text", "Dados do contrato")
        <div class="fpd-step-linha @(_etapaAtual > 1 ? "concluida" : "")"></div>
        @StepHeader(2, "bi-check2-square", "Verificações")
        <div class="fpd-step-linha @(_etapaAtual > 2 ? "concluida" : "")"></div>
        @StepHeader(3, "bi-cash-stack", "Valores")
    </div>

    <div class="dialog-fpd-corpo" @ref="_corpoRef">

        @if (_etapaAtual == 1)
        {
            <!-- ═══ ETAPA 1 — DADOS DO CONTRATO ═══ -->
            <div class="fpd-grupo-campos">
                <div class="fpd-ident">
                    <div class="fpd-campo fpd-campo-af">
                        <label class="fpd-label">Contrato AF <span class="fpd-obrigatorio">*</span></label>
                        <div class="fpd-af-linha">
                            <input class="fpd-input" placeholder="Ex.: 0558698-45" @bind="_fpd.ContratoAf" @bind:after="InvalidarValidacao" disabled="@_fpd.PrimeiroDesembolso" />
                            <button class="fpd-btn-buscar" @onclick="BuscarContrato" disabled="@(_buscando || _fpd.PrimeiroDesembolso)">
                                @if (_buscando) { <i class="bi bi-arrow-repeat spin"></i> } else { <i class="bi bi-search"></i> }
                                <span>Buscar</span>
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(_msgBusca)) { <span class="fpd-msg-busca @(_buscaOk ? "ok" : "falha")">@_msgBusca</span> }
                    </div>
                    <div class="fpd-campo"><label class="fpd-label">GIGOV</label>
                        <input class="fpd-input" @bind="_fpd.Gigov" @bind:after="InvalidarValidacao" /></div>
                    <div class="fpd-campo"><label class="fpd-label">Solicitante</label>
                        <input class="fpd-input" value="@_fpd.Solicitante" readonly /></div>
                    <div class="fpd-campo"><label class="fpd-label">Gestor</label>
                        <input class="fpd-input" @bind="_fpd.Gestor" /></div>
                    <div class="fpd-campo"><label class="fpd-label">Solicitado</label>
                        <input class="fpd-input" type="date" @bind="_fpd.DataSolicitado" /></div>
                </div>

                <label class="fpd-check fpd-check-destaque">
                    <input type="checkbox" @bind="_fpd.PrimeiroDesembolso" @bind:after="AoMudarPrimeiroDesembolso" />
                    <span>Este é o primeiro desembolso deste contrato</span>
                </label>

                <div class="fpd-agentes">
                    @CampoAgente("Agente Financeiro", _fpd.AgenteFinanceiro, v => _fpd.AgenteFinanceiro = v, _fpd.CnpjAgenteFinanceiro, v => _fpd.CnpjAgenteFinanceiro = v)
                    @CampoAgente("Tomador / Mutuário", _fpd.Tomador, v => _fpd.Tomador = v, _fpd.CnpjTomador, v => _fpd.CnpjTomador = v)
                    @CampoAgente("Agente Técnico OP", _fpd.AgenteTecnico, v => _fpd.AgenteTecnico = v, _fpd.CnpjAgenteTecnico, v => _fpd.CnpjAgenteTecnico = v)
                    @CampoAgente("Agente Promotor", _fpd.AgentePromotor, v => _fpd.AgentePromotor = v, _fpd.CnpjAgentePromotor, v => _fpd.CnpjAgentePromotor = v)
                    <div class="fpd-campo fpd-campo-cheio"><label class="fpd-label">Programa (automático)</label>
                        <input class="fpd-input" value="@_fpd.Programa" readonly placeholder="preenchido pela busca do contrato" /></div>
                </div>
                <div class="fpd-grid4">
                    <div class="fpd-campo"><label class="fpd-label">DT Emissão Eng.</label>
                        <input class="fpd-input" type="date" @bind="_fpd.DataEmissaoEng" /></div>
                    <div class="fpd-campo"><label class="fpd-label">Situação de obra</label>
                        <input class="fpd-input" @bind="_fpd.SituacaoObra" /></div>
                    <div class="fpd-campo">
                        <label class="fpd-label">DT Sócio-ambiental</label>
                        <div class="fpd-data-nsa">
                            <input class="fpd-input" type="date" @bind="_fpd.DataEmissaoSocioAmb" disabled="@_fpd.Nsa" />
                            <label class="fpd-check fpd-check-inline">
                                <input type="checkbox" @bind="_fpd.Nsa" /> <span>NSA</span>
                            </label>
                        </div>
                    </div>
                    <div class="fpd-campo"><label class="fpd-label">% de obra</label>
                        <input class="fpd-input" type="number" step="0.01" @bind="_fpd.PercObra" @bind:after="InvalidarValidacao" /></div>
                </div>
            </div>
        }
        else if (_etapaAtual == 2)
        {
            <!-- ═══ ETAPA 2 — VERIFICAÇÕES (árvore) ═══ -->
            <div class="fpd-grupo-head fpd-grupo-head-topo"><i class="bi bi-check2-square"></i><span>Verificações</span>
                <span class="fpd-grupo-hint">clique no item para comentar</span></div>
            <div class="fpd-arvore">
                @ItemToggle("2.1", "ultimo", "Último desembolso", () => _fpd.UltimoDesembolso, v => _fpd.UltimoDesembolso = v, false,
                    @<text>
                        @if (_fpd.UltimoDesembolso == "sim")
                        {
                            <div class="fpd-subtoggles">
                                <div class="fpd-sn-item"><label class="fpd-label">Funcionalidade</label>
                                    <ToggleSimNao @bind-Value="_fpd.Funcionalidade" AoAlterar="InvalidarValidacao" /></div>
                                <div class="fpd-sn-item"><label class="fpd-label">Conclusão</label>
                                    <ToggleSimNao @bind-Value="_fpd.Conclusao" AoAlterar="InvalidarValidacao" /></div>
                            </div>
                        }
                    </text>, _fpd.PrimeiroDesembolso)
                @ItemToggle("2.2", "licoperacao", "Licença de operação", () => _fpd.LicencaOperacao, v => _fpd.LicencaOperacao = v, true, null)
                @ItemToggle("2.3", "licinstalacao", "Licença de instalação", () => _fpd.LicencaInstalacao, v => _fpd.LicencaInstalacao = v, true, null)
                @ItemToggle("2.4", "tomadoradimp", "Tomador adimplente", () => _fpd.TomadorAdimplente, v => _fpd.TomadorAdimplente = v, false, null)
                @ItemToggle("2.5", "promotoradimp", "Agente Promotor adimplente", () => _fpd.PromotorAdimplente, v => _fpd.PromotorAdimplente = v, false, null)
                @ItemToggle("2.6", "placa", "Placa local", () => _fpd.PlacaLocal, v => _fpd.PlacaLocal = v, false, null)
                @ItemToggle("2.7", "retorno", "Retorno parcial", () => _fpd.RetornoParcial, v => _fpd.RetornoParcial = v, false, null)
                @ItemToggle("2.8", "excep", "Excepcionalização", () => _fpd.Excepcionalizacao, v => _fpd.Excepcionalizacao = v, false, null)
                @ItemToggle("2.9", "cpalterada", "CP alterada", () => _fpd.CpAlterada, v => _fpd.CpAlterada = v, false, null)
            </div>

            <div class="fpd-grupo-campos">
                <div class="fpd-campo fpd-campo-cheio"><label class="fpd-label">INSS OBS</label>
                    <textarea class="fpd-input fpd-textarea-sm" @bind="_fpd.InssObs"></textarea></div>
            </div>
        }
        else
        {
            <!-- ═══ ETAPA 3 — VALORES ═══ -->
            <div class="fpd-grupo-campos">
                <div class="fpd-check-destaque fpd-tipo-destaque fpd-tipo-destaque-topo">
                    <span class="fpd-tipo-rotulo">Tipo de desembolso</span>
                    <div class="fpd-tipo-opcoes">
                        <button type="button" class="fpd-tipo-opc @(_fpd.TipoDesembolso == "normal" ? "ativo" : "")"
                                @onclick='() => DefinirTipoDesembolso("normal")'>Normal</button>
                        <button type="button" class="fpd-tipo-opc @(_fpd.TipoDesembolso == "adiantamento" ? "ativo" : "")"
                                @onclick='() => DefinirTipoDesembolso("adiantamento")'>Adiantamento</button>
                    </div>
                </div>
                <div class="fpd-grid3">
                    <div class="fpd-campo"><label class="fpd-label">Solicitado VI</label><CampoMoeda @bind-Value="_fpd.SolicitadoVi" /></div>
                    <div class="fpd-campo"><label class="fpd-label">Glosado VI</label><CampoMoeda @bind-Value="_fpd.GlosadoVi" /></div>
                    <div class="fpd-campo"><label class="fpd-label">Aceito VI</label><CampoMoeda @bind-Value="_fpd.AceitoVi" /></div>
                    <div class="fpd-campo"><label class="fpd-label">Participação FGTS <span class="fpd-obrigatorio">*</span></label><CampoMoeda @bind-Value="_fpd.ParticipacaoFgts" AoAlterar="InvalidarValidacao" /></div>
                    <div class="fpd-campo"><label class="fpd-label">Contrapartida</label><CampoMoeda @bind-Value="_fpd.Contrapartida" AoAlterar="InvalidarValidacao" /></div>
                    <div class="fpd-campo"><label class="fpd-label">VE (Valor Empréstimo) <span class="fpd-obrigatorio">*</span></label><CampoMoeda @bind-Value="_fpd.Ve" AoAlterar="InvalidarValidacao" /></div>
                    <div class="fpd-campo"><label class="fpd-label">CP Atual</label><CampoMoeda @bind-Value="_fpd.CpAtual" /></div>
                    <div class="fpd-campo"><label class="fpd-label">Desembolsado</label><CampoMoeda @bind-Value="_fpd.Desembolsado" /></div>
                    <div class="fpd-campo"><label class="fpd-label">Integralizado</label><CampoMoeda @bind-Value="_fpd.Integralizado" /></div>
                    <div class="fpd-campo"><label class="fpd-label">Parcela FGTS</label><CampoMoeda @bind-Value="_fpd.ParcelaFgts" /></div>
                    <div class="fpd-campo"><label class="fpd-label">Integralizar</label><CampoMoeda @bind-Value="_fpd.Integralizar" /></div>
                    <div class="fpd-campo"><label class="fpd-label">Saldo a desembolsar</label><CampoMoeda @bind-Value="_fpd.SaldoDesembolsar" /></div>
                    <div class="fpd-campo"><label class="fpd-label">Saldo a integralizar</label><CampoMoeda @bind-Value="_fpd.SaldoIntegralizar" /></div>
                </div>
                @if (_fpd.TemValoresFinanceiros)
                {
                    <div class="fpd-perc">
                        <div class="fpd-perc-titulo">Percentuais</div>
                        <div class="fpd-perc-linha"><span>FGTS</span><strong>@FmtPerc(_fpd.PercFgts)</strong></div>
                        <div class="fpd-perc-linha"><span>Contrapartida</span><strong>@FmtPerc(_fpd.PercContrapartida)</strong></div>
                        <div class="fpd-perc-linha global"><span>Global</span><strong>@FmtPerc(_fpd.PercGlobal)</strong></div>
                    </div>
                }
                <div class="fpd-campo fpd-campo-cheio" style="margin-top:10px">
                    <label class="fpd-label">OBS AF</label>
                    <textarea class="fpd-input fpd-textarea" @bind="_fpd.ObsAf"></textarea>
                </div>
            </div>

            <!-- Resultado da validação -->
            @if (_validando || _etapas.Any())
            {
                <div class="fpd-validacao">
                    <div class="fpd-validacao-header">
                        <span>Consulta prévia no sistema</span>
                        @if (_status == StatusValidacao.Aprovado)  { <span class="fpd-validacao-tag ok">100% validado</span> }
                        @if (_status == StatusValidacao.Reprovado) { <span class="fpd-validacao-tag falha">pendências encontradas</span> }
                    </div>
                    <div class="fpd-linha-progresso @(_validando ? "ativa" : "")"></div>
                    <div class="fpd-validacao-lista">
                        @foreach (var etapa in _etapas)
                        {
                            <div class="fpd-etapa @etapa.Estado">
                                @if (etapa.Estado == "executando") { <i class="bi bi-arrow-repeat spin"></i> }
                                else if (etapa.Estado == "ok")     { <i class="bi bi-check-circle-fill"></i> }
                                else                               { <i class="bi bi-x-circle-fill"></i> }
                                <span>@etapa.Texto</span>
                                @if (!string.IsNullOrEmpty(etapa.Detalhe)) { <span class="fpd-etapa-detalhe">@etapa.Detalhe</span> }
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>

    <div class="dialog-fpd-rodape">
        <div class="dialog-fpd-acoes">
            <button class="btn-fpd-cancelar" @onclick="AoVoltar" disabled="@(_validando || _solicitando)">Cancelar</button>

            @if (_etapaAtual > 1)
            {
                <button class="btn-fpd-etapa-voltar" @onclick="EtapaAnterior" disabled="@(_validando || _solicitando)">
                    <i class="bi bi-chevron-left"></i> <span>Etapa anterior</span>
                </button>
            }

            <div class="fpd-rodape-espaco"></div>

            @if (_etapaAtual < 3)
            {
                <button class="btn-fpd-etapa-proxima" @onclick="ProximaEtapa">
                    <span>Próxima etapa</span> <i class="bi bi-chevron-right"></i>
                </button>
            }
            else
            {
                <button class="btn-fpd-validar" @onclick="Validar" disabled="@(_validando || _solicitando)">
                    @if (_validando) { <i class="bi bi-arrow-repeat spin"></i> <span>Validando…</span> }
                    else            { <i class="bi bi-shield-check"></i> <span>Validar</span> }
                </button>
                <button class="btn-fpd-solicitar" @onclick="Solicitar"
                        disabled="@(_status != StatusValidacao.Aprovado || _solicitando)"
                        title="@(_status == StatusValidacao.Aprovado ? "Enviar solicitação" : "Valide antes de solicitar")">
                    @if (_solicitando) { <i class="bi bi-arrow-repeat spin"></i> <span>Solicitando…</span> }
                    else              { <i class="bi bi-send-check"></i> <span>Solicitar Desembolso</span> }
                </button>
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public EventCallback AoVoltar { get; set; }
    [Parameter, EditorRequired] public EventCallback<PreenchimentoFpd> AoSolicitar { get; set; }

    private enum StatusValidacao { Nenhum, Aprovado, Reprovado }
    private sealed class Etapa { public string Texto = ""; public string Estado = "executando"; public string Detalhe = ""; }

    private readonly PreenchimentoFpd _fpd = new();
    private ElementReference _corpoRef;
    private readonly HashSet<string> _itensAbertos = [];
    private readonly Dictionary<string, List<Comentario>> _comentarios = new();

    private int _etapaAtual = 1;
    private bool _validando, _solicitando, _buscando, _buscaOk;
    private string? _msgBusca;
    private StatusValidacao _status = StatusValidacao.Nenhum;
    private readonly List<Etapa> _etapas = [];

    private static readonly (int Numero, string Icone, string Titulo)[] _stepsInfo =
    [
        (1, "bi-file-earmark-text", "Dados do contrato"),
        (2, "bi-check2-square",     "Verificações"),
        (3, "bi-cash-stack",        "Valores"),
    ];

    protected override void OnInitialized() => _fpd.Solicitante = ServicoUsuario.Matricula;

    private static string FmtPerc(decimal? p) => p is null ? "—" : $"{p.Value.ToString("0.000", new CultureInfo("pt-BR"))}%";

    // ── Stepper ──────────────────────────────────────────────────────────────
    private RenderFragment StepHeader(int numero, string icone, string titulo) =>
        @<button type="button" class="fpd-step @(EstadoEtapa(numero))" @onclick="() => IrParaEtapa(numero)" disabled="@(numero > _etapaAtual)">
            <span class="fpd-step-num">
                @if (numero < _etapaAtual) { <i class="bi bi-check-lg"></i> } else { @numero }
            </span>
            <span class="fpd-step-titulo">@titulo</span>
        </button>;

    private string EstadoEtapa(int numero) =>
        numero == _etapaAtual ? "atual" : numero < _etapaAtual ? "concluida" : "";

    // Só permite pular para etapas já visitadas (voltar) — avançar é sempre
    // via "Próxima etapa", nunca clicando direto num número futuro.
    private void IrParaEtapa(int numero)
    {
        if (numero > _etapaAtual) return;
        _etapaAtual = numero;
    }

    private void ProximaEtapa()
    {
        if (_etapaAtual < 3) _etapaAtual++;
    }

    private void EtapaAnterior()
    {
        if (_etapaAtual > 1) _etapaAtual--;
    }

    private RenderFragment CampoAgente(string rotulo, string valor, Action<string> setValor, string cnpj, Action<string> setCnpj) =>
        @<div class="fpd-campo">
            <label class="fpd-label">@rotulo</label>
            <div class="fpd-agente-linha">
                <input class="fpd-input" value="@valor" @onchange="e => setValor(e.Value?.ToString() ?? string.Empty)" />
                <input class="fpd-input fpd-cnpj" placeholder="CNPJ" value="@cnpj" @onchange="e => setCnpj(e.Value?.ToString() ?? string.Empty)" />
            </div>
        </div>;

    // Item da árvore (verificação Sim/Não). Título/chevron expande; toggle é independente.
    // Sem coloração verde/vermelho por resposta — só um indicador neutro de "respondido".
    private RenderFragment ItemToggle(string num, string chave, string titulo, Func<string?> get, Action<string?> set,
        bool comNsa, RenderFragment? extra, bool readOnly = false) =>
        @<div class="fpd-tree-item @(get() is not null ? "respondido" : "") @(_itensAbertos.Contains(chave) ? "aberto" : "")">
            <div class="fpd-tree-head">
                <button class="fpd-tree-abrir" @onclick="() => AlternarItem(chave)">
                    <span class="fpd-tree-num">@num</span>
                    <span class="fpd-tree-titulo">@titulo</span>
                </button>
                <ToggleSimNao Value="@get()" ValueChanged="v => DefinirItem(chave, v, set)" ComNsa="comNsa" ReadOnly="readOnly" />
                @if (ObterComentarios(chave).Count > 0) { <span class="fpd-tree-comm"><i class="bi bi-chat-text-fill"></i>@ObterComentarios(chave).Count</span> }
                <button class="fpd-tree-chevron-btn" @onclick="() => AlternarItem(chave)" title="Comentar">
                    <i class="bi bi-chevron-@(_itensAbertos.Contains(chave) ? "up" : "down")"></i>
                </button>
            </div>
            <div class="acc-body @(_itensAbertos.Contains(chave) ? "aberto" : "")">
                <div class="acc-inner">
                    <div class="fpd-tree-corpo">
                        @extra
                        <FioComentario Comentarios="ObterComentarios(chave)" ApenasInformativo="true" AoAdicionarComentario="c => AddComentario(chave, c)" />
                    </div>
                </div>
            </div>
        </div>;

    private void DefinirItem(string chave, string? valor, Action<string?> set)
    {
        set(valor);
        InvalidarValidacao();
        StateHasChanged();
    }

    private void AlternarItem(string chave) { if (!_itensAbertos.Remove(chave)) _itensAbertos.Add(chave); }
    private List<Comentario> ObterComentarios(string chave) => _comentarios.TryGetValue(chave, out var l) ? l : (_comentarios[chave] = []);
    private void AddComentario(string chave, Comentario c) => ObterComentarios(chave).Add(c);

    private async Task BuscarContrato()
    {
        if (_buscando || string.IsNullOrWhiteSpace(_fpd.ContratoAf)) return;
        _buscando = true; _msgBusca = null; StateHasChanged();
        try
        {
            var resp = await Http.GetAsync($"api/fpd/contrato?af={Uri.EscapeDataString(_fpd.ContratoAf)}");
            if (resp.IsSuccessStatusCode)
            {
                var c = await resp.Content.ReadFromJsonAsync<ContratoAfDto>();
                if (c is not null) PreencherDeContrato(c);
                _buscaOk = true; _msgBusca = "Contrato encontrado — campos preenchidos.";
            }
            else { _buscaOk = false; _msgBusca = "Contrato não encontrado — preencha manualmente."; }
        }
        catch (Exception ex) { _buscaOk = false; _msgBusca = "Falha na consulta."; Console.WriteLine($"[FPD] {ex.Message}"); }
        finally { _buscando = false; InvalidarValidacao(); StateHasChanged(); }
    }

    private void PreencherDeContrato(ContratoAfDto c)
    {
        _fpd.ContratoAf = c.ContratoAf; _fpd.Gigov = c.Gigov;
        _fpd.AgenteFinanceiro = c.AgenteFinanceiro; _fpd.CnpjAgenteFinanceiro = c.CnpjAgenteFinanceiro;
        _fpd.Tomador = c.Tomador; _fpd.CnpjTomador = c.CnpjTomador;
        _fpd.AgentePromotor = c.AgentePromotor; _fpd.CnpjAgentePromotor = c.CnpjAgentePromotor;
        _fpd.Programa = c.Programa; _fpd.Ve = c.Ve; _fpd.CpAtual = c.CpAtual;
        _fpd.Desembolsado = c.Desembolsado; _fpd.Integralizado = c.Integralizado;
        _fpd.SaldoDesembolsar = c.SaldoDesembolsar; _fpd.SaldoIntegralizar = c.SaldoIntegralizar;
        _fpd.PercObra = c.PercObra; _fpd.SituacaoObra = c.SituacaoObra;
    }

    private async Task Validar()
    {
        if (_validando) return;
        _validando = true; _status = StatusValidacao.Nenhum; _etapas.Clear(); StateHasChanged();
        try
        {
            var resposta = await Http.PostAsJsonAsync("api/fpd/validar", MontarRequisicao());
            resposta.EnsureSuccessStatusCode();
            var r = await resposta.Content.ReadFromJsonAsync<ValidacaoFpdResultado>() ?? new();
            foreach (var e in r.Etapas)
            {
                var etapa = new Etapa { Texto = e.Texto };
                _etapas.Add(etapa); StateHasChanged();
                await RolarAoFim(); await Task.Delay(240);
                etapa.Estado = e.Ok ? "ok" : "falha"; etapa.Detalhe = e.Detalhe; StateHasChanged();
                await RolarAoFim();
            }
            _status = r.Aprovado ? StatusValidacao.Aprovado : StatusValidacao.Reprovado;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[FPD] Validar: {ex.Message}");
            _etapas.Add(new Etapa { Estado = "falha", Texto = "Falha na consulta", Detalhe = "tente novamente" });
            _status = StatusValidacao.Reprovado;
        }
        finally { _validando = false; StateHasChanged(); }
    }

    private async Task RolarAoFim() { try { await JS.InvokeVoidAsync("sipubScrollFim", _corpoRef); } catch { } }

    private ValidacaoFpdRequest MontarRequisicao() => new()
    {
        Gigov = _fpd.Gigov, ContratoAf = _fpd.ContratoAf, Tomador = _fpd.Tomador,
        Ve = _fpd.Ve, ParticipacaoFgts = _fpd.ParticipacaoFgts, Contrapartida = _fpd.Contrapartida, PercObra = _fpd.PercObra,
        UltimoDesembolso = _fpd.UltimoDesembolso, Funcionalidade = _fpd.Funcionalidade, Conclusao = _fpd.Conclusao,
        PlacaLocal = _fpd.PlacaLocal, TomadorAdimplente = _fpd.TomadorAdimplente, PromotorAdimplente = _fpd.PromotorAdimplente,
    };

    private void InvalidarValidacao()
    {
        if (_status != StatusValidacao.Nenhum || _etapas.Count > 0) { _status = StatusValidacao.Nenhum; _etapas.Clear(); }
    }

    // Primeiro desembolso não tem "último desembolso" a comparar — força "não" e
    // trava o item na árvore (some também Funcionalidade/Conclusão). Também não
    // há contrato AF prévio a buscar, então o campo/botão de busca desabilita.
    private void AoMudarPrimeiroDesembolso()
    {
        if (_fpd.PrimeiroDesembolso)
        {
            _fpd.UltimoDesembolso = "nao";
            _fpd.Funcionalidade   = null;
            _fpd.Conclusao        = null;
        }
        InvalidarValidacao();
    }

    private void DefinirTipoDesembolso(string tipo)
    {
        if (_fpd.TipoDesembolso == tipo) return;
        _fpd.TipoDesembolso = tipo;
        InvalidarValidacao();
    }

    private async Task Solicitar()
    {
        if (_status != StatusValidacao.Aprovado || _solicitando) return;
        _solicitando = true;
        try
        {
            var req = MontarRequisicaoSolicitacao();
            var resposta = await Http.PostAsJsonAsync("api/fpd/solicitar", req);
            if (!resposta.IsSuccessStatusCode)
                Console.WriteLine($"[FPD] Endpoint de solicitação ainda não disponível ({(int)resposta.StatusCode}).");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[FPD] Solicitar: {ex.Message}");
        }
        finally
        {
            await AoSolicitar.InvokeAsync(_fpd);
            _solicitando = false;
        }
    }

    private SolicitacaoFpdRequest MontarRequisicaoSolicitacao() => new()
    {
        Solicitante = _fpd.Solicitante, Gigov = _fpd.Gigov, Gestor = _fpd.Gestor,
        IdFpd = _fpd.IdFpd, NumeroFpd = _fpd.NumeroFpd, ContratoAf = _fpd.ContratoAf,
        DataSolicitado = _fpd.DataSolicitado, PrimeiroDesembolso = _fpd.PrimeiroDesembolso,

        AgenteFinanceiro = _fpd.AgenteFinanceiro, CnpjAgenteFinanceiro = _fpd.CnpjAgenteFinanceiro,
        Tomador = _fpd.Tomador, CnpjTomador = _fpd.CnpjTomador,
        AgenteTecnico = _fpd.AgenteTecnico, CnpjAgenteTecnico = _fpd.CnpjAgenteTecnico,
        AgentePromotor = _fpd.AgentePromotor, CnpjAgentePromotor = _fpd.CnpjAgentePromotor,
        Programa = _fpd.Programa,

        UltimoDesembolso = _fpd.UltimoDesembolso, Funcionalidade = _fpd.Funcionalidade, Conclusao = _fpd.Conclusao,
        TomadorAdimplente = _fpd.TomadorAdimplente, PromotorAdimplente = _fpd.PromotorAdimplente,
        RetornoParcial = _fpd.RetornoParcial, PlacaLocal = _fpd.PlacaLocal,
        LicencaInstalacao = _fpd.LicencaInstalacao, LicencaOperacao = _fpd.LicencaOperacao,
        Excepcionalizacao = _fpd.Excepcionalizacao, CpAlterada = _fpd.CpAlterada,

        DataEmissaoEng = _fpd.DataEmissaoEng, SituacaoObra = _fpd.SituacaoObra,
        DataEmissaoSocioAmb = _fpd.DataEmissaoSocioAmb, Nsa = _fpd.Nsa,
        PercObra = _fpd.PercObra, TipoDesembolso = _fpd.TipoDesembolso, ObsAf = _fpd.ObsAf, InssObs = _fpd.InssObs,

        SolicitadoVi = _fpd.SolicitadoVi, GlosadoVi = _fpd.GlosadoVi, AceitoVi = _fpd.AceitoVi,
        ParticipacaoFgts = _fpd.ParticipacaoFgts, Contrapartida = _fpd.Contrapartida, Ve = _fpd.Ve,
        CpAtual = _fpd.CpAtual, Desembolsado = _fpd.Desembolsado, Integralizado = _fpd.Integralizado,
        ParcelaFgts = _fpd.ParcelaFgts, Integralizar = _fpd.Integralizar,
        SaldoDesembolsar = _fpd.SaldoDesembolsar, SaldoIntegralizar = _fpd.SaldoIntegralizar,
    };
}

