<div class="linha @("linha-" + Desembolso.Status) @(Selecionada ? "linha-selecionada" : "")"
     role="button" @onclick="AoClicarLinha" tabindex="0"
     @onkeydown="TratarTecla">

    <!-- Contrato -->
    <div class="col-contrato">
        <span class="contrato-mono">@Desembolso.Contrato</span>
    </div>

    <!-- Mutuário (opcional — a PaginaAnalise oculta; a /2 mantém) -->
    @if (MostrarMutuario)
    {
    <div class="col-mutuario">
        <span class="mutuario-nome" title="@Desembolso.Mutuario">@Desembolso.Mutuario</span>
    </div>
    }

    <!-- GIGOV -->
    <div class="col-gigov">
        <span class="gigov-badge">@Desembolso.Gigov</span>
    </div>

    <!-- Valor -->
    <div class="col-valor">@ServicoMock.FormatarBRL(Desembolso.Valor)</div>

    <!-- Aguardando (opcional — a PaginaAnalise oculta; a /2 mantém) -->
    @if (MostrarAguardando)
    {
    <div class="col-aguardando">
        @if (Desembolso.Status == "pendencia")
        {
            <span class="aguardando-na">—</span>
        }
        else if (PendentesCount == 0)
        {
            <span class="aguardando-ok">
                <i class="bi bi-check2"></i>
                Todas OK
            </span>
        }
        else
        {
            <span class="aguardando-count @(PendentesCount >= 4 ? "aguardando-critico" : "aguardando-warn")">
                <strong class="aguardando-num">@PendentesCount</strong>
                <span class="aguardando-label">aguardando</span>
            </span>
        }
    </div>
    }

    <!-- Situação -->
    <div class="col-situacao">
        <PilulhaStatus Status="@Desembolso.Status" />
    </div>

    <!-- Prazo -->
    <div class="col-prazo">
        <span class="prazo-chip">
            <i class="bi bi-calendar3"></i>
            @ServicoMock.FormatarPrazo(Desembolso.PrazoFinal)
        </span>
    </div>

    <!-- Responsável -->
    <div class="col-responsavel" @onclick:stopPropagation>
        @if (Analista is not null)
        {
            <button class="btn-responsavel btn-atribuido" @onclick="@((MouseEventArgs e) => AbrirAtribuicao(e))" title="@Analista.Nome">
                <span class="resp-avatar" style="background:@Analista.Cor">@Analista.Iniciais</span>
                <span class="resp-nome">@Analista.Nome</span>
                <i class="bi bi-chevron-down resp-chevron"></i>
            </button>
        }
        else
        {
            <button class="btn-responsavel btn-nao-atribuido" @onclick="@((MouseEventArgs e) => AbrirAtribuicao(e))">
                <i class="bi bi-person resp-icone"></i>
                Não atribuído
                <i class="bi bi-chevron-down resp-chevron"></i>
            </button>
        }
    </div>

    <!-- Arrow (aparece no hover) -->
    <div class="col-arrow">
        <i class="bi bi-arrow-right linha-arrow"></i>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public DesembolsoCAD  Desembolso { get; set; } = null!;
    [Parameter] public Funcionario? Analista    { get; set; }
    [Parameter] public bool         MostrarAguardando { get; set; } = true;
    [Parameter] public bool         MostrarMutuario   { get; set; } = true;
    [Parameter] public bool         Selecionada { get; set; }
    [Parameter] public EventCallback AoClicar   { get; set; }
    [Parameter] public EventCallback<MouseEventArgs> AoAtribuir { get; set; }

    private int PendentesCount => Desembolso.ValidacoesTotal - Desembolso.ValidacoesOk;

    private async Task AoClicarLinha() => await AoClicar.InvokeAsync();

    private async Task AbrirAtribuicao(MouseEventArgs e)
        => await AoAtribuir.InvokeAsync(e);

    private async Task TratarTecla(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or " ")
            await AoClicarLinha();
    }
}


<style>
/* ─ Linha base ─ */
.linha {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 20px;
    border-top: 1px solid var(--ink-100);
    cursor: pointer;
    transition: background .1s;
    user-select: none;
    min-width: 0;
}
.linha:first-child { border-top: none; }
.linha:hover { background: #F4F8FD; }
.linha:hover .linha-arrow { opacity: 1; }
.linha-selecionada { background: var(--brand-50) !important; box-shadow: inset 2px 0 0 var(--brand-500); }

/* ─ Colunas (larguras espelham o React: w-36 w-52 w-20 w-28 w-32 w-32 w-20 w-44 w-5) ─ */

/* Contrato — 144px, mono, brand-800 */
.col-contrato { width: 144px; flex-shrink: 0; overflow: hidden; }
.contrato-mono {
    font-family: 'Courier New', Courier, monospace;
    font-size: 13px;
    font-weight: 700;
    color: var(--brand-800);
}

/* Mutuário — 208px, truncate */
.col-mutuario { width: 208px; flex-shrink: 0; min-width: 0; overflow: hidden; }
.mutuario-nome {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: var(--ink-900);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

/* GIGOV — 80px, badge centralizado */
.col-gigov { width: 80px; flex-shrink: 0; display: flex; justify-content: center; }
.gigov-badge {
    display: inline-flex;
    align-items: center;
    border-radius: var(--radius-md);
    border: 1px solid var(--ink-100);
    background: var(--ink-50);
    padding: 2px 8px;
    font-family: ui-monospace, 'Cascadia Code', 'Roboto Mono', Menlo, Consolas, monospace;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--ink-700);
}

/* Valor — 112px, alinhado à direita */
.col-valor {
    width: 112px;
    flex-shrink: 0;
    text-align: right;
    font-size: 13px;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    color: var(--ink-900);
}

/* Aguardando — 128px, centralizado */
.col-aguardando {
    width: 128px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
}
.aguardando-na {
    font-size: 13px;
    color: var(--ink-300);
    font-weight: 500;
    letter-spacing: 0.05em;
}
.aguardando-ok {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    border-radius: var(--radius-lg);
    background: #F0FDF4;
    border: 1px solid #BEEACE;
    padding: 4px 10px;
    font-size: 10.5px;
    font-weight: 700;
    color: #1A7A4A;
}
.aguardando-ok i { font-size: 10px; }
.aguardando-count {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    border-radius: var(--radius-lg);
    padding: 4px 10px;
}
.aguardando-critico { background: #FEF2F2; color: #9A2A1F; }
.aguardando-warn    { background: #FFFBEB; color: #663A00; }
.aguardando-num   { font-size: 13px; font-weight: 800; font-variant-numeric: tabular-nums; line-height: 1; }
.aguardando-label { font-size: 10px; font-weight: 500; opacity: .7; }

/* Situação — 128px */
.col-situacao { width: 128px; flex-shrink: 0; }

/* Prazo — 80px, chip centralizado */
.col-prazo { width: 80px; flex-shrink: 0; display: flex; justify-content: center; }
.prazo-chip {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    border-radius: var(--radius-lg);
    border: 1px solid var(--brand-200);
    background: var(--brand-50);
    padding: 4px 8px;
    font-size: 10.5px;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    color: var(--brand-800);
    white-space: nowrap;
}
.prazo-chip i { font-size: 10px; color: var(--brand-700); }

/* Responsável — 176px */
.col-responsavel { width: 176px; flex-shrink: 0; }
.btn-responsavel {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border-radius: var(--radius-lg);
    font-size: 11px;
    font-weight: 600;
    font-family: inherit;
    transition: all .15s;
    cursor: pointer;
    padding: 4px 8px;
    max-width: 100%;
}
.btn-atribuido {
    background: #fff;
    border: 1px solid var(--ink-100);
    color: var(--ink-700);
    box-shadow: var(--shadow-card);
}
.btn-atribuido:hover { background: var(--ink-50); }
.btn-nao-atribuido {
    background: transparent;
    border: 1px dashed var(--ink-200);
    color: var(--ink-300);
}
.btn-nao-atribuido:hover { border-color: var(--brand-300); color: var(--brand-700); }
.resp-avatar {
    width: 20px; height: 20px;
    border-radius: 50%;
    color: #fff;
    font-size: 8.5px;
    font-weight: 700;
    display: grid;
    place-items: center;
    flex-shrink: 0;
}
.resp-nome {
    max-width: 88px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}
.resp-icone  { font-size: 11px; }
.resp-chevron { font-size: 10px; color: var(--ink-300); margin-left: auto; }

/* Arrow (aparece no hover via .linha:hover .linha-arrow) */
.col-arrow { width: 20px; flex-shrink: 0; display: flex; align-items: center; }
.linha-arrow {
    font-size: 14px;
    color: var(--brand-700);
    opacity: 0;
    transition: opacity .15s;
}
</style>
