{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-server",
            "type": "process",
            "command": "dotnet",
            "args": [
                "build",
                "${workspaceFolder}/Server/SipubDesembolsos.Server.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile",
            "group": "build"
        },
        {
            "label": "build-client",
            "type": "process",
            "command": "dotnet",
            "args": [
                "build",
                "${workspaceFolder}/Client/SipubDesembolsos.Client.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile",
            "group": "build"
        },
        {
            "label": "build-solucao",
            "type": "process",
            "command": "dotnet",
            "args": [
                "build",
                "${workspaceFolder}/SipubDesembolsos.slnx",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "watch-server",
            "type": "process",
            "command": "dotnet",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/Server/SipubDesembolsos.Server.csproj"
            ],
            "isBackground": true,
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch-client",
            "type": "process",
            "command": "dotnet",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/Client/SipubDesembolsos.Client.csproj"
            ],
            "isBackground": true,
            "problemMatcher": "$msCompile"
        }
    ]
}
